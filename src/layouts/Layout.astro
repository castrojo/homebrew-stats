---
import TabNav from '../components/TabNav.astro';
import IssueButton from '../components/IssueButton.astro';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'homebrew' | 'testhub' | 'overall' | 'contributors' | 'builds' | 'aurora-builds' | 'bazzite-builds' | 'universal-blue' | 'ucore' | 'zirconium' | 'bootcrew' | 'secureblue';
}
const { title = 'bootc ecosystem', description = 'Health dashboard for the bootc image ecosystem', activeTab } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/bootc-logo.svg`} />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        let theme;
        if (stored === 'light' || stored === 'dark') {
          theme = stored;
        } else {
          // system default — respect OS preference
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* Carbon dark + bootc purple accents */
        --bg:       #161616;
        --bg2:      #262626;
        --bg3:      #1e1e1e;
        --border:   #393939;
        --text:     #f4f4f4;
        --muted:    #8d8d8d;
        --link:     #af68d9;
        --green:    #24a148;
        --yellow:   #f1c21b;
        --red:      #fa4d56;
        --purple:   #af68d9;
        --blue:     #9232a9;
        --indigo:   #6929c4;
        --accent:   #78298b;
        --card-shadow: 0 1px 4px rgba(0,0,0,0.45);
      }

      [data-theme="light"] {
        --bg:       #ffffff;
        --bg2:      #f4f4f4;
        --bg3:      #f8f8f8;
        --border:   #e0e0e0;
        --text:     #161616;
        --muted:    #525252;
        --link:     #6929c4;
        --green:    #198038;
        --yellow:   #b28600;
        --red:      #da1e28;
        --purple:   #8a3ffc;
        --blue:     #6929c4;
        --indigo:   #4f2196;
        --accent:   #6929c4;
        --card-shadow: 0 1px 3px rgba(0,0,0,0.10);
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        font-size: 14px;
        line-height: 1.5;
        min-height: 100vh;
      }

      .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 24px 16px;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 16px;
        margin-bottom: 40px;
      }

      header h1 {
        font-size: 22px;
        font-weight: 600;
        color: var(--text);
      }

      .meta {
        font-size: 12px;
        color: var(--muted);
        margin-top: 4px;
      }

      .meta a { color: var(--link); text-decoration: none; }
      .meta a:hover { text-decoration: underline; }

      h2 {
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
        margin: 32px 0 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
        padding-left: 10px;
        border-left: 3px solid var(--accent);
      }

      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }

      footer {
        margin-top: 64px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--muted);
        text-align: center;
      }

      /* Card depth — picked up by ChartCard and KPI components */
      :global(.chart-card),
      :global(.kpi-card) {
        box-shadow: var(--card-shadow);
      }
    </style>
  </head>
  <body>
    <div class="container">
      {activeTab && <TabNav activeTab={activeTab} />}
      {activeTab && <IssueButton />}
      <slot />
      <footer>
        Data refreshed daily via GitHub Actions · 
        <a href="https://github.com/castrojo/bootc-ecosystem">castrojo/bootc-ecosystem</a> · 
        Built with <a href="https://astro.build">Astro</a> + <a href="https://www.chartjs.org">Chart.js</a>
      </footer>
    </div>
    <script>
      const btn = document.getElementById('theme-toggle') as HTMLButtonElement | null;
      if (btn) {
        const modes = ['system', 'light', 'dark'] as const;
        type Mode = typeof modes[number];
        const icons: Record<Mode, string> = { system: '🖥', light: '☀️', dark: '🌙' };

        function getSystemTheme() {
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        function applyMode(mode: Mode) {
          const resolved = mode === 'system' ? getSystemTheme() : mode;
          document.documentElement.dataset.theme = resolved;
          if (mode === 'system') {
            localStorage.removeItem('theme');
          } else {
            localStorage.setItem('theme', mode);
          }
          btn.textContent = icons[mode];
          btn.title = `Theme: ${mode}`;
          window.dispatchEvent(new CustomEvent('themechange'));
        }

        function getCurrentMode(): Mode {
          const stored = localStorage.getItem('theme');
          if (stored === 'light' || stored === 'dark') return stored;
          return 'system';
        }

        // Initialize
        applyMode(getCurrentMode());

        btn.addEventListener('click', () => {
          const current = getCurrentMode();
          const next = modes[(modes.indexOf(current) + 1) % modes.length];
          applyMode(next);
        });

        // Keep system mode in sync with OS preference changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
          if (getCurrentMode() === 'system') applyMode('system');
        });
      }
    </script>
  </body>
</html>
