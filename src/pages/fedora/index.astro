---
import Layout from '../../layouts/Layout.astro';
import ChartCard from '../../components/ChartCard.astro';
import { safeJson } from '../../lib/inject.ts';
import rawData from '../../data/quay-fedora.json';

interface DailyStat {
  date: string;
  count: number;
}

interface Stream {
  name: string;
  last_modified: string;
  arch_count: number;
}

interface QuayRepo {
  label: string;
  namespace: string;
  repo: string;
  daily_stats: DailyStat[];
  streams: Stream[];
  pulls_7d: number;
}

interface QuayData {
  generated_at: string;
  repos: QuayRepo[];
  total_pulls_7d: number;
  total_pulls_30d: number;
  combined_daily: DailyStat[];
}

interface StreamRow {
  repoLabel: string;
  name: string;
  lastModified: string;
  archCount: number;
  ageText: string;
  status: 'fresh' | 'warm' | 'stale';
}

const data = rawData as unknown as QuayData;
const isBootstrap = !data.generated_at;
const generatedAt = data.generated_at ? new Date(data.generated_at).toUTCString() : '';
const numberFmt = new Intl.NumberFormat('en-US');
const nowMs = data.generated_at ? new Date(data.generated_at).getTime() : Date.now();

function ageInfo(lastModified: string): { ageText: string; status: StreamRow['status'] } {
  const ts = new Date(lastModified).getTime();
  if (Number.isNaN(ts)) return { ageText: 'Unknown', status: 'stale' };
  const ageHours = Math.max(0, Math.floor((nowMs - ts) / 3_600_000));
  const ageText = ageHours < 1 ? '<1h ago' : ageHours < 24 ? `${ageHours}h ago` : `${Math.floor(ageHours / 24)}d ago`;
  const status = ageHours < 24 ? 'fresh' : ageHours <= 72 ? 'warm' : 'stale';
  return { ageText, status };
}

const coreosRepo = data.repos.find((repo) => repo.repo === 'fedora-coreos') ?? data.repos[0];
const bootcRepo = data.repos.find((repo) => repo.repo === 'fedora-bootc') ?? data.repos[1];

const streamRows: StreamRow[] = data.repos.flatMap((repo) =>
  (repo.streams ?? []).map((stream) => {
    const age = ageInfo(stream.last_modified);
    return {
      repoLabel: repo.label,
      name: stream.name,
      lastModified: stream.last_modified,
      archCount: stream.arch_count,
      ageText: age.ageText,
      status: age.status,
    };
  }),
);

const chartData = {
  combinedDaily: data.combined_daily ?? [],
  coreosDaily: coreosRepo?.daily_stats ?? [],
  bootcDaily: bootcRepo?.daily_stats ?? [],
};
---

<Layout title="Fedora bootc Images" activeTab={'fedora' as any}>
  <header class="page-header">
    <div>
      <h1>Fedora bootc Images</h1>
      <p class="meta">
        {generatedAt && <>Updated {generatedAt} · </>}
        <a href="https://quay.io/repository/fedora/fedora-coreos" target="_blank" rel="noopener">Fedora CoreOS</a>
        {' · '}
        <a href="https://quay.io/repository/fedora/fedora-bootc" target="_blank" rel="noopener">Fedora bootc</a>
        {' · '}
        <a href="https://fedoraproject.org/" target="_blank" rel="noopener">fedoraproject.org</a>
      </p>
    </div>
  </header>

  {isBootstrap ? (
    <p class="collecting">Collecting data — check back after next CI run</p>
  ) : (
    <>
      <section class="kpi-grid">
        <article class="kpi-card"><div class="kpi-label">Total 7d pulls</div><div class="kpi-value">{numberFmt.format(data.total_pulls_7d ?? 0)}</div></article>
        <article class="kpi-card"><div class="kpi-label">Total 30d pulls</div><div class="kpi-value">{numberFmt.format(data.total_pulls_30d ?? 0)}</div></article>
        <article class="kpi-card"><div class="kpi-label">CoreOS 7d</div><div class="kpi-value">{numberFmt.format(coreosRepo?.pulls_7d ?? 0)}</div></article>
        <article class="kpi-card"><div class="kpi-label">bootc 7d</div><div class="kpi-value">{numberFmt.format(bootcRepo?.pulls_7d ?? 0)}</div></article>
      </section>

      <ChartCard title="Combined Daily Pull Trend" canvasId="fedora-combined-chart" height={280} />
      <ChartCard title="Pull Breakdown by Image" canvasId="fedora-stacked-chart" height={220} />

      <section class="table-section">
        <h2>Stream Freshness</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Repository</th>
                <th>Stream</th>
                <th>Last Modified</th>
                <th>Age</th>
                <th>Architectures</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {streamRows.map((row) => (
                <tr>
                  <td>{row.repoLabel}</td>
                  <td class="mono">{row.name}</td>
                  <td>{row.lastModified}</td>
                  <td>{row.ageText}</td>
                  <td>{row.archCount}</td>
                  <td>
                    <span class={`status-badge ${row.status}`}>
                      <span class="dot"></span>
                      {row.status === 'fresh' ? 'Fresh' : row.status === 'warm' ? 'Aging' : 'Stale'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <script type="application/json" id="fedora-quay-data" set:html={safeJson(chartData)} />
      <script>
        import '../../lib/chart-registry.js';
        import { Chart } from 'chart.js';
        import { getChartColors } from '../../lib/chart-theme.js';
        import { readChartData } from '../../lib/inject.js';

        function makeGradient(chart, topColor, bottomColor) {
          const { ctx, chartArea } = chart;
          if (!chartArea) return topColor;
          const g = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
          g.addColorStop(0, topColor);
          g.addColorStop(1, bottomColor);
          return g;
        }

        function movingAvg(data, window = 7) {
          return data.map((_, i) => {
            const slice = data.slice(Math.max(0, i - window + 1), i + 1);
            return { x: data[i].x, y: Math.round(slice.reduce((s, p) => s + p.y, 0) / slice.length) };
          });
        }

        const fmt = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });
        const fmtFull = new Intl.NumberFormat('en-US');
        const payload = readChartData('fedora-quay-data');
        const colors = getChartColors();

        const combinedPoints = (payload.combinedDaily ?? []).map((d) => ({ x: d.date, y: d.count }));
        const avgPoints = movingAvg(combinedPoints);

        const allDates = (payload.combinedDaily ?? []).map((d) => d.date);
        const coreosMap = new Map((payload.coreosDaily ?? []).map((d) => [d.date, d.count]));
        const bootcMap = new Map((payload.bootcDaily ?? []).map((d) => [d.date, d.count]));
        const coreosValues = allDates.map((d) => coreosMap.get(d) ?? 0);
        const bootcValues = allDates.map((d) => bootcMap.get(d) ?? 0);

        const combinedCanvas = document.getElementById('fedora-combined-chart');
        const stackedCanvas = document.getElementById('fedora-stacked-chart');
        let combinedChart;
        let stackedChart;

        if (combinedCanvas) {
          combinedChart = new Chart(combinedCanvas, {
            type: 'line',
            data: { datasets: [{
              label: 'Daily pulls',
              data: combinedPoints,
              borderColor: '#af68d9',
              backgroundColor: (ctx) => makeGradient(ctx.chart, 'rgba(175,104,217,0.45)', 'rgba(175,104,217,0.02)'),
              fill: 'origin',
              tension: 0.35,
              cubicInterpolationMode: 'monotone',
              borderWidth: 2.5,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHitRadius: 20,
              pointHoverBackgroundColor: '#af68d9',
            }, {
              label: '7-day avg',
              data: avgPoints,
              borderColor: 'rgba(175,104,217,0.5)',
              borderDash: [5, 3],
              fill: false,
              tension: 0.35,
              borderWidth: 1.5,
              pointRadius: 0,
            }]},
            options: {
              responsive: true,
              maintainAspectRatio: false,
              interaction: { mode: 'index', intersect: false },
              plugins: {
                legend: { labels: { color: 'var(--text)', usePointStyle: true, pointStyleWidth: 10 } },
                filler: { propagate: true },
                tooltip: {
                  mode: 'index', intersect: false,
                  backgroundColor: 'rgba(38,38,38,0.97)',
                  titleColor: '#f4f4f4',
                  bodyColor: '#c6c6c6',
                  borderColor: 'rgba(175,104,217,0.4)',
                  borderWidth: 1,
                  padding: 12,
                  callbacks: {
                    title: (items) => {
                      const date = items[0]?.raw?.x ?? items[0]?.label ?? '';
                      return new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                    },
                    label: (ctx) => ` ${ctx.dataset.label}: ${fmtFull.format(ctx.parsed.y)} pulls`,
                  },
                },
              },
              scales: {
                x: {
                  type: 'category',
                  ticks: { color: colors.muted, maxTicksLimit: 8, autoSkip: true },
                  grid: { color: colors.grid },
                  border: { color: colors.grid },
                },
                y: {
                  beginAtZero: true,
                  ticks: { color: colors.muted, callback: (v) => fmt.format(v) },
                  grid: { color: colors.grid },
                  border: { color: colors.grid },
                },
              },
            },
          });
        }

        if (stackedCanvas) {
          stackedChart = new Chart(stackedCanvas, {
            type: 'line',
            data: {
              labels: allDates,
              datasets: [
                { label: 'Fedora CoreOS', data: coreosValues, borderColor: '#af68d9', backgroundColor: 'rgba(175,104,217,0.35)', fill: true, stack: 'q', tension: 0.35, pointRadius: 0, borderWidth: 2 },
                { label: 'Fedora bootc', data: bootcValues, borderColor: '#78a9ff', backgroundColor: 'rgba(120,169,255,0.30)', fill: true, stack: 'q', tension: 0.35, pointRadius: 0, borderWidth: 2 },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              interaction: { mode: 'index', intersect: false },
              plugins: {
                legend: { labels: { color: colors.text, usePointStyle: true, pointStyleWidth: 10 } },
                tooltip: {
                  mode: 'index',
                  intersect: false,
                  callbacks: {
                    label: (ctx) => ` ${ctx.dataset.label}: ${fmtFull.format(ctx.parsed.y)} pulls`,
                  },
                },
              },
              scales: {
                x: {
                  type: 'category',
                  ticks: { color: colors.muted, maxTicksLimit: 8, autoSkip: true },
                  grid: { color: colors.grid },
                  border: { color: colors.grid },
                },
                y: {
                  stacked: true,
                  beginAtZero: true,
                  ticks: { color: colors.muted, callback: (v) => fmt.format(v) },
                  grid: { color: colors.grid },
                  border: { color: colors.grid },
                },
              },
            },
          });
        }

        function applyThemeToChart(chart) {
          const isDark = document.documentElement.dataset.theme === 'dark';
          const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
          const textColor = isDark ? '#8d8d8d' : '#525252';
          chart.options.scales.x.ticks.color = textColor;
          chart.options.scales.x.grid.color = gridColor;
          chart.options.scales.y.ticks.color = textColor;
          chart.options.scales.y.grid.color = gridColor;
          chart.options.plugins.legend.labels.color = isDark ? '#f4f4f4' : '#161616';
          chart.update('none');
        }

        window.addEventListener('themechange', () => {
          if (combinedChart) applyThemeToChart(combinedChart);
          if (stackedChart) applyThemeToChart(stackedChart);
        });
      </script>
    </>
  )}
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; margin-bottom: 0.3rem; }
  .meta { color: var(--muted); font-size: 0.85rem; }
  .collecting { color: var(--muted); margin-bottom: 1.5rem; }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .kpi-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem;
  }
  .kpi-label { color: var(--muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .kpi-value { color: var(--accent); font-size: 1.5rem; font-weight: 700; margin-top: 0.3rem; }

  .table-section { margin-top: 1rem; }
  .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 8px; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 0.65rem 0.75rem; border-bottom: 1px solid var(--border); text-align: left; }
  th { color: var(--muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
  tbody tr:nth-child(odd) { background: var(--bg); }
  tbody tr:nth-child(even) { background: var(--bg2); }
  .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

  .status-badge { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; padding: 0.2rem 0.45rem; border-radius: 999px; border: 1px solid var(--border); }
  .status-badge .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
  .status-badge.fresh .dot { background: var(--green); }
  .status-badge.warm .dot { background: var(--yellow); }
  .status-badge.stale .dot { background: var(--red); }
  :global(.chart-card) { box-shadow: var(--card-shadow); }

  @media (max-width: 900px) {
    .kpi-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
