---
import Layout from '../../layouts/Layout.astro';
import CountmeKPIs from '../../components/CountmeKPIs.astro';
import CountmeTrendChart from '../../components/CountmeTrendChart.astro';
import DistroTrendChart from '../../components/DistroTrendChart.astro';
import EcosystemPieChart from '../../components/EcosystemPieChart.astro';
import EcosystemGrowthChart from '../../components/EcosystemGrowthChart.astro';
import data from '../../data/countme.json';
import DORAComparisonSection from '../../components/DORAComparisonSection.astro';
import FutureProofedPanel from '../../components/FutureProofedPanel.astro';
import type { BuildsData, BuildRepoMetrics } from '../../lib/types.ts';
import bluefinBuilds from '../../data/builds-bluefin.json';
import auroraBuilds from '../../data/builds-aurora.json';
import bazziteBuilds from '../../data/builds-bazzite.json';

const generatedAt = new Date(data.generated_at).toUTCString();
const weekRecords = data.history.week_records ?? [];

/**
 * Derive a boolean | null for a supply chain metric from a builds dataset.
 * Uses per-repo rate fields (sign_step_success_rate_30d / sbom_step_success_rate_30d).
 * -1 means "step not detected in pipeline" — treated the same as missing data (null).
 * If at least one repo has real data, use the mean rate; threshold >= 80 → true.
 */
function deriveRate(
  repos: BuildRepoMetrics[],
  field: 'sign_step_success_rate_30d' | 'sbom_step_success_rate_30d',
): boolean | null {
  const validRates = repos
    .map(r => r[field])
    .filter((v): v is number => v !== undefined && v !== -1);
  if (validRates.length === 0) return null;
  const mean = validRates.reduce((a, b) => a + b, 0) / validRates.length;
  return mean >= 80;
}

const bluefinRepos = (bluefinBuilds as unknown as BuildsData).repos ?? [];
const auroraRepos  = (auroraBuilds  as unknown as BuildsData).repos ?? [];
const bazziteRepos = (bazziteBuilds as unknown as BuildsData).repos ?? [];

const imageProofData = [
  {
    label: 'Bluefin',
    signing:     deriveRate(bluefinRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(bluefinRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: null as boolean | null,
    chunka:      null as boolean | null,
  },
  {
    label: 'Aurora',
    signing:     deriveRate(auroraRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(auroraRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: null as boolean | null,
    chunka:      null as boolean | null,
  },
  {
    label: 'Bazzite',
    signing:     deriveRate(bazziteRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(bazziteRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: null as boolean | null,
    chunka:      null as boolean | null,
  },
];
---

<Layout title="Overall — homebrew-stats" activeTab="overall">
  <header>
    <h1>Universal Blue Active Devices</h1>
    <div class="meta">
      Updated {generatedAt} ·
      <a href="https://github.com/ublue-os/countme">ublue-os/countme</a>
    </div>
    <button id="theme-toggle" aria-label="Toggle dark/light mode" title="Toggle theme">🌙</button>
  </header>

  <div class="explainer">
    <p>
      These counts come from <strong>countme</strong>, a privacy-respecting feature built into
      <a href="https://fedoraproject.org/wiki/Changes/DNF_Better_Counting" target="_blank" rel="noopener">Fedora's package manager</a>.
      Once a week, each device sends a single anonymous check-in — no personal data, no IP addresses stored,
      just a count of how many devices are actively using each image.
      Think of it like a headcount: it tells us how many devices checked in this week, not who they are or what they did.
    </p>
  </div>

  <CountmeKPIs
    currentWeek={data.current_week as any}
    wowGrowthPct={data.wow_growth_pct as any}
    weekRecords={weekRecords as any}
  />

  <DORAComparisonSection
    bluefin={bluefinBuilds as unknown as BuildsData}
    aurora={auroraBuilds as unknown as BuildsData}
    bazzite={bazziteBuilds as unknown as BuildsData}
  />

  <h2>Future Proofed</h2>
  <FutureProofedPanel images={imageProofData} />

  <section class="charts-section">
    <h2>Monthly Trends</h2>
    <CountmeTrendChart weekRecords={weekRecords as any} />

    <h2>Individual Image Trends</h2>
    <div class="distro-charts-grid">
      <DistroTrendChart distroKey="bazzite"    distroLabel="Bazzite"    colorIndex={0} weekRecords={weekRecords as any} defaultRange="365" />
      <DistroTrendChart distroKey="bluefin"    distroLabel="Bluefin"    colorIndex={1} weekRecords={weekRecords as any} defaultRange="365" />
      <DistroTrendChart distroKey="aurora"     distroLabel="Aurora"     colorIndex={3} weekRecords={weekRecords as any} defaultRange="365" />
    </div>

    <h2>Ecosystem Share</h2>
    <EcosystemPieChart currentWeek={data.current_week as any} />

    <h2>Device Momentum (This Week vs Last Week)</h2>
    <EcosystemGrowthChart currentWeek={data.current_week as any} prevWeek={data.prev_week as any} />
  </section>
</Layout>

<style>
  .charts-section { margin-bottom: 48px; }
  .distro-charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }
  .explainer {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blue);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 28px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }
  .explainer p { margin: 0; }
  .explainer strong { color: var(--text); }
  .explainer a { color: var(--blue); }
</style>
