---
import Layout from '../../layouts/Layout.astro';
import CountmeKPIs from '../../components/CountmeKPIs.astro';
import CountmeTrendChart from '../../components/CountmeTrendChart.astro';
import DistroTrendChart from '../../components/DistroTrendChart.astro';
import EcosystemPieChart from '../../components/EcosystemPieChart.astro';
import EcosystemGrowthChart from '../../components/EcosystemGrowthChart.astro';
import data from '../../data/countme.json';
import DORAComparisonSection from '../../components/DORAComparisonSection.astro';
import FutureProofedPanel from '../../components/FutureProofedPanel.astro';
import type { BuildsData, BuildRepoMetrics } from '../../lib/types.ts';
import bluefinBuilds from '../../data/builds-bluefin.json';
import auroraBuilds from '../../data/builds-aurora.json';
import bazziteBuilds from '../../data/builds-bazzite.json';
import universalBlueBuilds from '../../data/builds-universal-blue.json';
import ucoreBuilds from '../../data/builds-ucore.json';
import zirconiumBuilds from '../../data/builds-zirconium.json';
import bootcrewBuilds from '../../data/builds-bootcrew.json';
import supplyChainRaw from '../../data/supply-chain.json';

const generatedAt = new Date(data.generated_at).toUTCString();
const weekRecords = data.history.week_records ?? [];

// ── Countme distros shown across all countme-aware sections ──────────────────
const countmeDistros = [
  { key: 'bazzite',     label: 'Bazzite',     color: 'var(--blue)'   },
  { key: 'bluefin',     label: 'Bluefin',     color: 'var(--purple)' },
  { key: 'bluefin-lts', label: 'Bluefin LTS', color: 'var(--indigo)' },
  { key: 'aurora',      label: 'Aurora',      color: 'var(--green)'  },
  { key: 'secureblue',  label: 'secureblue',  color: 'var(--yellow)' },
];

// ── Supply chain helper ──────────────────────────────────────────────────────
/**
 * Derive a boolean | null for a supply chain metric from a builds dataset.
 * -1 means "step not detected in pipeline" — treated as null (no data).
 * Uses the MAX rate across repos: if the best-performing repo in the ecosystem
 * signs reliably (>= 80%), the ecosystem has signing. Mean was too punishing
 * when helper repos (iso, common) have lower rates due to CI instability.
 */
function deriveRate(
  repos: BuildRepoMetrics[],
  field: 'sign_step_success_rate_30d' | 'sbom_step_success_rate_30d',
): boolean | null {
  const validRates = repos
    .map(r => r[field])
    .filter((v): v is number => v !== undefined && v !== -1);
  if (validRates.length === 0) return null;
  const max = Math.max(...validRates);
  return max >= 80;
}

const bluefinRepos       = (bluefinBuilds      as unknown as BuildsData).repos ?? [];
const auroraRepos        = (auroraBuilds       as unknown as BuildsData).repos ?? [];
const bazziteRepos       = (bazziteBuilds      as unknown as BuildsData).repos ?? [];
const universalBlueRepos = (universalBlueBuilds as unknown as BuildsData).repos ?? [];
const ucoreRepos         = (ucoreBuilds        as unknown as BuildsData).repos ?? [];
const zirconiumRepos     = (zirconiumBuilds    as unknown as BuildsData).repos ?? [];
const bootcrewRepos      = (bootcrewBuilds     as unknown as BuildsData).repos ?? [];
const supplyChain = supplyChainRaw as Record<string, {
  zstd_chunked: boolean | null;
  chunka_detected: boolean | null;
  legacy_rechunk: boolean | null;
  slsa_provenance: boolean | null;
}>;

function chunkaState(label: string): 'chunkah' | 'legacy' | null {
  const sc = supplyChain[label];
  if (!sc) return null;
  if (sc.chunka_detected === true) return 'chunkah';
  if (sc.legacy_rechunk === true) return 'legacy';
  return null;
}

// ── DORA images — all 7 with build pipelines ─────────────────────────────────
const doraImages = [
  { label: 'Bluefin',       color: 'var(--blue)',   data: bluefinBuilds      as unknown as BuildsData },
  { label: 'Aurora',        color: 'var(--green)',  data: auroraBuilds       as unknown as BuildsData },
  { label: 'Bazzite',       color: 'var(--orange)', data: bazziteBuilds      as unknown as BuildsData },
  { label: 'ublue-os',      color: 'var(--purple)', data: universalBlueBuilds as unknown as BuildsData },
  { label: 'uCore',         color: 'var(--indigo)', data: ucoreBuilds        as unknown as BuildsData },
  { label: 'Zirconium',     color: 'var(--yellow)', data: zirconiumBuilds    as unknown as BuildsData },
  { label: 'bootcrew',      color: 'var(--red)',    data: bootcrewBuilds     as unknown as BuildsData },
];

// ── Future Proofed — all 7 ────────────────────────────────────────────────────
const imageProofData = [
  {
    label: 'Bluefin',
    signing:     deriveRate(bluefinRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(bluefinRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['Bluefin']?.zstd_chunked ?? null,
    chunka:      chunkaState('Bluefin'),
    slsa:        supplyChain['Bluefin']?.slsa_provenance ?? null,
  },
  {
    label: 'Aurora',
    signing:     deriveRate(auroraRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(auroraRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['Aurora']?.zstd_chunked ?? null,
    chunka:      chunkaState('Aurora'),
    slsa:        supplyChain['Aurora']?.slsa_provenance ?? null,
  },
  {
    label: 'Bazzite',
    signing:     deriveRate(bazziteRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(bazziteRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['Bazzite']?.zstd_chunked ?? null,
    chunka:      chunkaState('Bazzite'),
    slsa:        supplyChain['Bazzite']?.slsa_provenance ?? null,
  },
  {
    label: 'ublue-os',
    signing:     deriveRate(universalBlueRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(universalBlueRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['ublue-os']?.zstd_chunked ?? null,
    chunka:      chunkaState('ublue-os'),
    slsa:        supplyChain['ublue-os']?.slsa_provenance ?? null,
  },
  {
    label: 'uCore',
    signing:     deriveRate(ucoreRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(ucoreRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['uCore']?.zstd_chunked ?? null,
    chunka:      chunkaState('uCore'),
    slsa:        supplyChain['uCore']?.slsa_provenance ?? null,
  },
  {
    label: 'Zirconium',
    signing:     deriveRate(zirconiumRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(zirconiumRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['Zirconium']?.zstd_chunked ?? null,
    chunka:      chunkaState('Zirconium'),
    slsa:        supplyChain['Zirconium']?.slsa_provenance ?? null,
  },
  {
    label: 'bootcrew',
    signing:     deriveRate(bootcrewRepos, 'sign_step_success_rate_30d'),
    sbom:        deriveRate(bootcrewRepos, 'sbom_step_success_rate_30d'),
    zstdChunked: supplyChain['bootcrew']?.zstd_chunked ?? null,
    chunka:      chunkaState('bootcrew'),
    slsa:        supplyChain['bootcrew']?.slsa_provenance ?? null,
  },
];

// countme images that have individual trend charts (countme-visible only)
const countmeTrendImages = [
  { distroKey: 'bazzite',     distroLabel: 'Bazzite',     colorIndex: 0 },
  { distroKey: 'bluefin',     distroLabel: 'Bluefin',     colorIndex: 1 },
  { distroKey: 'aurora',      distroLabel: 'Aurora',      colorIndex: 3 },
  { distroKey: 'secureblue',  distroLabel: 'secureblue',  colorIndex: 4 },
];
---

<Layout title="bootc — bootc-ecosystem" activeTab="overall">
  <header>
    <h1>bootc Active Devices</h1>
    <div class="meta">
      Updated {generatedAt} ·
      <a href="https://github.com/ublue-os/countme">ublue-os/countme</a>
    </div>
    <button id="theme-toggle" aria-label="Toggle dark/light mode" title="Toggle theme">🌙</button>
  </header>

  <div class="explainer">
    <p>
      These counts come from <strong>countme</strong>, a privacy-respecting feature built into
      <a href="https://fedoraproject.org/wiki/Changes/DNF_Better_Counting" target="_blank" rel="noopener">Fedora's package manager</a>.
      Once a week, each device sends a single anonymous check-in — no personal data, no IP addresses stored,
      just a count of how many devices are actively using each image.
      Think of it like a headcount: it tells us how many devices checked in this week, not who they are or what they did.
    </p>
  </div>

  <CountmeKPIs
    currentWeek={data.current_week as any}
    wowGrowthPct={data.wow_growth_pct as any}
    weekRecords={weekRecords as any}
    images={countmeDistros}
  />

  <DORAComparisonSection images={doraImages} />

  <h2>Future Proofed</h2>
  <FutureProofedPanel images={imageProofData} />

  <section class="charts-section">
    <h2>Monthly Trends</h2>
    <CountmeTrendChart weekRecords={weekRecords as any} distros={countmeDistros} />

    <h2>Individual Image Trends</h2>
    <div class="distro-charts-grid">
      {countmeTrendImages.map(img => (
        <DistroTrendChart
          distroKey={img.distroKey}
          distroLabel={img.distroLabel}
          colorIndex={img.colorIndex}
          weekRecords={weekRecords as any}
          defaultRange="365"
        />
      ))}
    </div>

    <h2>Ecosystem Share</h2>
    <EcosystemPieChart currentWeek={data.current_week as any} distros={countmeDistros} />

    <h2>Device Momentum (This Week vs Last Week)</h2>
    <EcosystemGrowthChart
      currentWeek={data.current_week as any}
      prevWeek={data.prev_week as any}
      distros={countmeDistros}
    />
  </section>
</Layout>

<style>
  .charts-section { margin-bottom: 48px; }
  .distro-charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 20px;
  }
  .explainer {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blue);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 28px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }
  .explainer p { margin: 0; }
  .explainer strong { color: var(--text); }
  .explainer a { color: var(--blue); }
</style>
