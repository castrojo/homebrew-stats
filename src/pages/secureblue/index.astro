---
import Layout from '../../layouts/Layout.astro';
import CountmeSingleChart from '../../components/CountmeSingleChart.astro';
import countme from '../../data/countme.json';

const weekRecords = (countme as any).history?.week_records ?? [];
const currentWeek = (countme as any).current_week;
const prevWeek = (countme as any).prev_week;
const activeDevices = currentWeek?.distros?.secureblue ?? 0;
const prevActiveDevices = prevWeek?.distros?.secureblue ?? 0;
const wowChange = activeDevices - prevActiveDevices;
const wowChangeDisplay = wowChange === 0 ? '0' : `${wowChange > 0 ? '+' : ''}${wowChange.toLocaleString()}`;
const wowChangeClass = wowChange > 0 ? 'positive' : wowChange < 0 ? 'negative' : 'neutral';
const ecosystemTotal = currentWeek?.total_all_distros ?? currentWeek?.total ?? 0;
const pctOfEcosystem = ecosystemTotal > 0 ? Number(((activeDevices / ecosystemTotal) * 100).toFixed(1)) : 0;
const variantEntries = Object.entries(currentWeek?.distros ?? {}).filter(([key]) => key.startsWith('secureblue-'));
const knownVariants = ['GNOME', 'KDE', 'Cosmic', 'Sericea', 'Server'];
---

<Layout title="secureblue" activeTab="secureblue">
  <header class="page-header">
    <div>
      <h1>secureblue</h1>
      <div class="meta">
        A security-hardened bootc image ·
        <a href="https://github.com/secureblue/secureblue" target="_blank" rel="noopener">secureblue/secureblue</a> ·
        <a href="https://secureblue.dev" target="_blank" rel="noopener">secureblue.dev</a>
      </div>
    </div>
  </header>

  <section class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-value">{activeDevices.toLocaleString()}</div>
      <div class="kpi-label">Active Devices (current week)</div>
    </div>
    <div class="kpi-card">
      <div class={`kpi-value ${wowChangeClass}`}>{wowChangeDisplay}</div>
      <div class="kpi-label">Week Change</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-value">{pctOfEcosystem}%</div>
      <div class="kpi-label">% of Ecosystem</div>
    </div>
  </section>

  <section class="variant-section">
    <h3>Variants</h3>
    <div class="variant-grid">
      {variantEntries.length > 0 ? (
        variantEntries.map(([name, count]) => (
          <div class="variant-card">
            <div class="variant-name">{name}</div>
            <div class="variant-count">{Number(count).toLocaleString()}</div>
          </div>
        ))
      ) : (
        knownVariants.map((name) => (
          <div class="variant-card">
            <div class="variant-name">{name}</div>
            <div class="variant-count">—</div>
          </div>
        ))
      )}
    </div>
    {variantEntries.length === 0 && (
      <p class="variant-note">Variant breakdown not yet available in countme data</p>
    )}
  </section>

  <section class="info-section">
    <p>
      secureblue provides hardened Fedora bootc images for multiple desktop environments
      (GNOME, KDE, Cosmic, Sericea) and server targets (IoT, Securecore).
      All variants — including nvidia builds — report as <code>secureblue</code> in Fedora countme data.
    </p>
  </section>

  <CountmeSingleChart
    weekRecords={weekRecords}
    distroKey="secureblue"
    label="secureblue"
    canvasId="secureblue-trend"
  />

  <p class="ecosystem-note">
    secureblue represents {pctOfEcosystem}% of all tracked bootc ecosystem active devices.
  </p>

  <section class="resources">
    <h3>Resources</h3>
    <ul>
      <li><a href="https://github.com/secureblue/secureblue" target="_blank">GitHub — secureblue/secureblue</a></li>
      <li><a href="https://secureblue.dev" target="_blank">secureblue.dev</a></li>
    </ul>
  </section>
</Layout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  h1 { font-size: 1.75rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .meta { font-size: 0.8rem; color: var(--muted); }
  .meta a { color: var(--link); text-decoration: none; }
  .meta a:hover { text-decoration: underline; }
  code { font-size: 0.85em; background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; padding: 0.1em 0.35em; }

  .kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .kpi-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .kpi-value { font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1.1; }
  .kpi-value.positive { color: var(--green); }
  .kpi-value.negative { color: var(--red); }
  .kpi-value.neutral { color: var(--text); }
  .kpi-label { font-size: 11px; color: var(--muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em; }

  .variant-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .variant-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 8px; margin: 1rem 0 0.5rem; }
  .variant-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 6px; padding: 12px; text-align: center; }
  .variant-card .variant-name { font-size: 12px; color: var(--muted); font-weight: 600; }
  .variant-card .variant-count { font-size: 1.4rem; font-weight: 700; color: var(--text); margin-top: 4px; }
  .variant-note {
    margin: 0 0 2rem;
    font-size: 12px;
    color: var(--muted);
  }

  .info-section { margin-bottom: 1.5rem; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
  .ecosystem-note {
    margin-top: 0.75rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .resources {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .resources h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .resources ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  .resources a {
    color: var(--link);
    text-decoration: none;
  }
  .resources a:hover {
    text-decoration: underline;
  }
</style>
