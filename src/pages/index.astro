---
import Layout from '../layouts/Layout.astro';
import TrafficChart from '../components/TrafficChart.astro';
import DownloadsChart from '../components/DownloadsChart.astro';
import TapComparisonChart from '../components/TapComparisonChart.astro';
import OsSection from '../components/OsSection.astro';
import HeroKPIs from '../components/HeroKPIs.astro';
import PackageLeaderboard from '../components/PackageLeaderboard.astro';
import stats from '../data/stats.json';

const generatedAt = new Date(stats.generated_at).toUTCString();
const tapNames = stats.taps.map((t: any) => t.name);
const stableTap = stats.taps[0] as any;
---

<Layout title="ublue-os Homebrew Tap Stats" activeTab="homebrew">
  <header>
    <h1>ublue-os Homebrew Tap Health</h1>
    <div class="meta">
      Updated {generatedAt} ·
      <a href="https://github.com/ublue-os/homebrew-tap">homebrew-tap</a> ·
      <a href="https://github.com/ublue-os/homebrew-experimental-tap">homebrew-experimental-tap</a>
    </div>
    <button id="theme-toggle" aria-label="Toggle dark/light mode" title="Toggle theme">🌙</button>
  </header>

  <!-- Hero KPI row: aggregated stats across all taps at a glance -->
  <HeroKPIs summary={(stats as any).summary} taps={stats.taps as any} />

  <hr class="section-divider" />

  <!-- Sortable leaderboard: all packages across both taps -->
  <PackageLeaderboard taps={stats.taps as any} />

  {stats.history.length > 1 && (
    <section class="charts-section">
      <h2>Trends</h2>
      <div class="charts-zone-full">
        <TrafficChart history={stats.history} tapNames={tapNames} />
      </div>
      <div class="charts-zone-two">
        <DownloadsChart tapName={stableTap.name} history={stats.history} />
      </div>
      <div class="charts-zone-full">
        <TapComparisonChart history={stats.history} tapNames={tapNames} />
      </div>
    </section>
  )}

  {(stats as any).os_analytics && (
    <>
      <h2>OS Analytics (Linux)</h2>
      <OsSection osAnalytics={(stats as any).os_analytics} />
    </>
  )}

</Layout>

<style>
  .charts-section {
    margin-bottom: 48px;
  }

  .charts-zone-full {
    margin-bottom: 20px;
  }

  .charts-zone-two {
    margin-bottom: 20px;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 8px 0 32px;
  }
</style>
