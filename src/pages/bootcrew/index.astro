---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="bootcrew" activeTab="bootcrew">
  <header class="page-header">
    <div>
      <h1>bootcrew</h1>
      <div class="meta">
        Multi-distro bootc images (Arch, Debian, Ubuntu, openSUSE) ·
        <a href="https://github.com/bootcrew/mono" target="_blank" rel="noopener">bootcrew/mono</a>
      </div>
    </div>
  </header>

  <section class="info-section">
    <p>
      bootcrew builds bootc images on top of non-Fedora base distributions, including Arch Linux,
      Debian, Ubuntu, and openSUSE Tumbleweed.
    </p>
    <p class="notice">
      <strong>Note:</strong> bootcrew images are not Fedora-based and do not participate in Fedora
      countme data collection. GitHub and registry metrics are coming soon.
    </p>
  </section>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  h1 { font-size: 1.75rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .meta { font-size: 0.8rem; color: var(--muted); }
  .meta a { color: var(--link); text-decoration: none; }
  .meta a:hover { text-decoration: underline; }
  .info-section { margin-bottom: 1.5rem; color: var(--muted); font-size: 0.9rem; line-height: 1.6; }
  .info-section strong { color: var(--text); }
  .notice {
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--yellow);
    border-radius: 4px;
  }
</style>
