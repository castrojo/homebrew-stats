---
interface DaySnapshot {
  date: string;
  taps: Record<string, { uniques: number; count: number }>;
}

interface Props {
  history: DaySnapshot[];
  tapNames: string[];
}

const { history, tapNames } = Astro.props;

// Colours per tap (consistent ordering).
const COLOURS = ['#388bfd', '#a371f7', '#3fb950', '#d29922'];
---

<div class="chart-card">
  <div class="chart-header">
    <div class="chart-title">Unique Tappers Over Time</div>
    <div class="range-btns" id="traffic-range-btns">
      <button class="range-btn active" data-range="30">30d</button>
      <button class="range-btn" data-range="90">90d</button>
      <button class="range-btn" data-range="all">All</button>
    </div>
  </div>
  <div class="chart-wrap">
    <canvas id="traffic-chart"></canvas>
  </div>
</div>
<script type="application/json" id="traffic-data">{JSON.stringify({ history, tapNames, COLOURS })}</script>

<script>
  import Chart from 'chart.js/auto';

  const { history: allHistory, tapNames, COLOURS } = JSON.parse(
    document.getElementById('traffic-data')!.textContent!
  );

  function getCSSVar(name) {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }
  function getChartColors() {
    return {
      text: getCSSVar('--text'),
      muted: getCSSVar('--muted'),
      grid: getCSSVar('--border'),
    };
  }

  function buildDatasets(data) {
    return tapNames.map((name, i) => ({
      label: name,
      data: data.map(s => s.taps[name]?.uniques ?? null),
      borderColor: COLOURS[i % COLOURS.length],
      backgroundColor: COLOURS[i % COLOURS.length] + '22',
      fill: true,
      tension: 0.3,
      pointRadius: data.length < 15 ? 4 : 2,
      spanGaps: true,
    }));
  }

  function getWindow(range) {
    if (range === '30') return allHistory.slice(-30);
    if (range === '90') return allHistory.slice(-90);
    return allHistory;
  }

  let current = getWindow('30');
  const colors = getChartColors();

  let chart;
  try {
    chart = new Chart(document.getElementById('traffic-chart'), {
      type: 'line',
      data: {
        labels: current.map(s => s.date),
        datasets: buildDatasets(current),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            labels: { color: colors.text, font: { size: 12 } },
          },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'} unique tappers`,
            },
          },
        },
        scales: {
          x: {
            ticks: { color: colors.muted, font: { size: 11 }, maxRotation: 45 },
            grid: { color: colors.grid },
          },
          y: {
            beginAtZero: true,
            ticks: {
              color: colors.muted,
              font: { size: 11 },
              callback: v => v.toLocaleString(),
            },
            grid: { color: colors.grid },
            title: { display: true, text: 'Unique Tappers', color: colors.muted, font: { size: 11 } },
          },
        },
      },
    });
  } catch (e) {
    console.error('[TrafficChart] Chart.js init failed:', e);
  }

  // Time range selector
  document.querySelectorAll('#traffic-range-btns .range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      document.querySelectorAll('#traffic-range-btns .range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const data = getWindow(btn.dataset.range);
      chart.data.labels = data.map(s => s.date);
      chart.data.datasets = buildDatasets(data);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const c = getChartColors();
    chart.options.plugins.legend.labels.color = c.text;
    chart.options.scales.x.ticks.color = c.muted;
    chart.options.scales.x.grid.color = c.grid;
    chart.options.scales.y.ticks.color = c.muted;
    chart.options.scales.y.grid.color = c.grid;
    chart.options.scales.y.title.color = c.muted;
    chart.update();
  });
</script>

<style>
  .chart-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
    margin-bottom: 0;
  }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .chart-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .chart-wrap {
    position: relative;
    height: 260px;
  }

  .range-btns {
    display: flex;
    gap: 4px;
  }

  .range-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 11px;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .range-btn:hover {
    background: var(--bg);
    color: var(--text);
  }

  .range-btn.active {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
</style>
