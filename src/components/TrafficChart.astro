---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface Props {
  history: { date: string; taps: Record<string, { uniques: number; count: number }> }[];
  tapNames: string[];
}

const { history, tapNames } = Astro.props;
---

<ChartCard
  title="Install Trend by Tap"
  canvasId="traffic-chart"
  height={260}
  rangeId="traffic-range-btns"
  ranges={[{ label: '30d', value: '30' }, { label: '90d', value: '90' }, { label: '365d', value: '365' }, { label: 'All', value: 'all' }]}
  defaultRange="30"
/>
<script type="application/json" id="traffic-data" set:html={safeJson({ history, tapNames })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { history: allHistory, tapNames } = readChartData<{
    history: { date: string; taps: Record<string, { count: number; downloads?: Record<string, number> }> }[];
    tapNames: string[];
  }>('traffic-data');

  function makeGradient(chart: Chart, topColor: string, bottomColor: string): string | CanvasGradient {
    const { ctx, chartArea } = chart;
    if (!chartArea) return topColor;
    const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
    gradient.addColorStop(0, topColor);
    gradient.addColorStop(1, bottomColor);
    return gradient;
  }

  function getTapInstalls(snapshot: (typeof allHistory)[number], tapName: string): number | null {
    const downloads = snapshot.taps[tapName]?.downloads;
    if (downloads) {
      return Object.values(downloads).reduce((sum, value) => sum + value, 0);
    }
    const fallback = snapshot.taps[tapName]?.count;
    return typeof fallback === 'number' ? fallback : null;
  }

  function buildDatasets(data: typeof allHistory) {
    return tapNames.map((name, i) => ({
      label: name,
      data: data.map(s => getTapInstalls(s, name)),
      borderColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
      backgroundColor: (ctx: { chart: Chart }) =>
        makeGradient(
          ctx.chart,
          `${BRAND_COLOURS[i % BRAND_COLOURS.length]}66`,
          `${BRAND_COLOURS[i % BRAND_COLOURS.length]}05`
        ),
      fill: 'origin',
      tension: 0.35,
      cubicInterpolationMode: 'monotone' as const,
      borderWidth: 2.5,
      pointRadius: data.length < 15 ? 3 : 0,
      pointHoverRadius: 4,
      spanGaps: true,
    }));
  }

  function getWindow(range: string) {
    if (range === '30') return allHistory.slice(-30);
    if (range === '90') return allHistory.slice(-90);
    if (range === '365') return allHistory.slice(-365);
    return allHistory;
  }

  let current = getWindow('30');
  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('traffic-chart') as HTMLCanvasElement, {
      type: 'line',
      data: {
        labels: current.map(s => s.date),
        datasets: buildDatasets(current),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
            legend: {
              labels: { color: colors.text, font: { size: 12 } },
            },
            tooltip: {
              callbacks: {
                label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'} installs`,
              },
            },
          },
          scales: {
            x: {
              type: 'category',
              ticks: { color: colors.muted, font: { size: 11 }, maxRotation: 45 },
              grid: { color: colors.grid },
            },
            y: {
              beginAtZero: true,
              ticks: {
                color: colors.muted,
                font: { size: 11 },
                callback: v => Number(v).toLocaleString(),
              },
              grid: { color: colors.grid },
              title: { display: true, text: 'Installs', color: colors.muted, font: { size: 11 } },
            },
          },
        },
      });
  } catch (e) {
    console.error('[TrafficChart] Chart.js init failed:', e);
  }

  document.querySelectorAll('#traffic-range-btns .range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      document.querySelectorAll('#traffic-range-btns .range-btn').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      const data = getWindow((btn as HTMLElement).dataset.range!);
      chart.data.labels = data.map(s => s.date);
      chart.data.datasets = buildDatasets(data);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
    chart.update('none');
  });
</script>
