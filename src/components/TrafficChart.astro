---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface Props {
  history: { date: string; taps: Record<string, { uniques: number; count: number }> }[];
  tapNames: string[];
}

const { history, tapNames } = Astro.props;
---

<ChartCard
  title="Unique Tappers Over Time"
  canvasId="traffic-chart"
  height={260}
  rangeId="traffic-range-btns"
  ranges={[{ label: '30d', value: '30' }, { label: '90d', value: '90' }, { label: 'All', value: 'all' }]}
  defaultRange="30"
/>
<script type="application/json" id="traffic-data" set:html={safeJson({ history, tapNames })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { history: allHistory, tapNames } = readChartData<{
    history: { date: string; taps: Record<string, { uniques: number }> }[];
    tapNames: string[];
  }>('traffic-data');

  function buildDatasets(data: typeof allHistory) {
    return tapNames.map((name, i) => ({
      label: name,
      data: data.map(s => s.taps[name]?.uniques ?? null),
      borderColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
      backgroundColor: BRAND_COLOURS[i % BRAND_COLOURS.length] + '22',
      fill: true,
      tension: 0.3,
      pointRadius: data.length < 15 ? 4 : 2,
      spanGaps: true,
    }));
  }

  function getWindow(range: string) {
    if (range === '30') return allHistory.slice(-30);
    if (range === '90') return allHistory.slice(-90);
    return allHistory;
  }

  let current = getWindow('30');
  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('traffic-chart') as HTMLCanvasElement, {
      type: 'line',
      data: {
        labels: current.map(s => s.date),
        datasets: buildDatasets(current),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            labels: { color: colors.text, font: { size: 12 } },
          },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'} unique tappers`,
            },
          },
        },
        scales: {
          x: {
            ticks: { color: colors.muted, font: { size: 11 }, maxRotation: 45 },
            grid: { color: colors.grid },
          },
          y: {
            beginAtZero: true,
            ticks: {
              color: colors.muted,
              font: { size: 11 },
              callback: v => Number(v).toLocaleString(),
            },
            grid: { color: colors.grid },
            title: { display: true, text: 'Unique Tappers', color: colors.muted, font: { size: 11 } },
          },
        },
      },
    });
  } catch (e) {
    console.error('[TrafficChart] Chart.js init failed:', e);
  }

  document.querySelectorAll('#traffic-range-btns .range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      document.querySelectorAll('#traffic-range-btns .range-btn').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      const data = getWindow((btn as HTMLElement).dataset.range!);
      chart.data.labels = data.map(s => s.date);
      chart.data.datasets = buildDatasets(data);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
