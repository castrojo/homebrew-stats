---
import type { BuildsData, BuildMonthlySnapshot } from '../lib/types.ts';
import { doraLevelColor } from '../lib/build-utils.ts';
import { safeJson } from '../lib/inject.ts';

interface ImageInput {
  label: string;
  color: string;   // CSS color string e.g. 'var(--blue)'
  data: BuildsData;
}

interface Props {
  images: ImageInput[];
}

const { images } = Astro.props;

interface ImageDORA {
  label: string;
  level: string;
  deployFreq: number;
  changeFailRate: number;
  color: string;
}

const imageCards: ImageDORA[] = images.map(img => ({
  label: img.label,
  level: img.data.dora_metrics.dora_level,
  deployFreq: img.data.dora_metrics.deploy_freq_per_week,
  changeFailRate: img.data.dora_metrics.change_failure_rate_pct,
  color: img.color,
}));

// Monthly leaderboard — union of all months across all images
const allMonths = Array.from(new Set(
  images.flatMap(img => (img.data.monthly_history ?? []).map((s: BuildMonthlySnapshot) => s.month))
)).sort();

function buildLevelMap(history: BuildMonthlySnapshot[] | null | undefined): Record<string, string> {
  const m: Record<string, string> = {};
  for (const s of history ?? []) { m[s.month] = s.dora_level; }
  return m;
}

function levelToNum(level: string | undefined): number | null {
  switch (level) {
    case 'elite':  return 4;
    case 'high':   return 3;
    case 'medium': return 2;
    case 'low':    return 1;
    default:       return null;
  }
}

interface ChartDataset {
  label: string;
  color: string;
  values: (number | null)[];
}

const chartDatasets: ChartDataset[] = images.map(img => {
  const levelMap = buildLevelMap(img.data.monthly_history);
  return {
    label: img.label,
    color: img.color,
    values: allMonths.map(m => levelToNum(levelMap[m])),
  };
});

const showChart = allMonths.length >= 2;

interface ChartPayload {
  labels: string[];
  datasets: ChartDataset[];
}

const chartPayload: ChartPayload = { labels: allMonths, datasets: chartDatasets };
---

<section class="dora-comparison">
  <h2 class="section-heading">Project DORA Health</h2>

  <!-- KPI cards -->
  <div class="dora-cards" style={`grid-template-columns: repeat(${Math.min(imageCards.length, 4)}, 1fr)`}>
    {imageCards.map(img => (
      <div class="dora-card">
        <div class="dora-image-label">{img.label}</div>
        {img.level === 'unknown' ? (
          <div class="dora-level collecting">Collecting…</div>
        ) : (
          <>
            <div
              class="dora-level"
              style={`color: ${doraLevelColor(img.level)}`}
            >
              {img.level.charAt(0).toUpperCase() + img.level.slice(1)}
            </div>
            <div class="dora-stat">{img.deployFreq.toFixed(1)}×/wk deploys</div>
            <div class="dora-stat">{img.changeFailRate.toFixed(1)}% fail rate</div>
          </>
        )}
      </div>
    ))}
  </div>

  <!-- Monthly leaderboard chart -->
  {showChart && (
    <div class="dora-chart-wrap">
      <canvas id="dora-comparison-chart" height={220} aria-label="Monthly DORA level leaderboard" role="img"></canvas>
      <script type="application/json" id="dora-comparison-data" set:html={safeJson(chartPayload)}></script>
    </div>
  )}
</section>

<script>
import '../lib/chart-registry.js';
import { readChartData } from '../lib/inject.js';
import { getChartColors, applyTheme } from '../lib/chart-theme.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('dora-comparison-data');
if (dataEl) {
  interface ChartDataset {
    label: string;
    color: string;
    values: (number | null)[];
  }
  interface ChartPayload {
    labels: string[];
    datasets: ChartDataset[];
  }

  try {
    const payload = readChartData<ChartPayload>('dora-comparison-data');
    const colors = getChartColors();

    const levelLabels = ['', 'Low', 'Medium', 'High', 'Elite'];

    // Resolve CSS vars to hex at runtime so Chart.js can use them
    const style = getComputedStyle(document.documentElement);
    function resolveCSSVar(v: string): string {
      const match = v.match(/var\((--[\w-]+)\)/);
      if (match) return style.getPropertyValue(match[1]).trim();
      return v;
    }

    const chart = new Chart('dora-comparison-chart', {
      type: 'bar',
      data: {
        labels: payload.labels,
        datasets: payload.datasets.map(ds => {
          const hex = resolveCSSVar(ds.color);
          return {
            label: ds.label,
            data: ds.values,
            backgroundColor: hex + 'cc',
            borderColor: hex,
            borderWidth: 1,
          };
        }),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: colors.text, font: { size: 12 } } },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const v = ctx.parsed.y;
                return `${ctx.dataset.label}: ${levelLabels[v] ?? 'Unknown'}`;
              },
            },
          },
        },
        scales: {
          x: {
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
          },
          y: {
            min: 0,
            max: 4,
            ticks: {
              color: colors.muted,
              font: { size: 11 },
              stepSize: 1,
              callback: (v) => levelLabels[v as number] ?? '',
            },
            grid: { color: colors.grid },
          },
        },
      },
    });

    window.addEventListener('themechange', () => applyTheme(chart));
  } catch (e) {
    console.error('[DORAComparisonSection]', e);
  }
}
</script>

<style>
  .dora-comparison {
    margin-bottom: 2rem;
  }

  .section-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .dora-cards {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .dora-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .dora-image-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dora-level {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .dora-level.collecting {
    color: var(--muted);
    font-size: 1rem;
  }

  .dora-stat {
    font-size: 11px;
    color: var(--muted);
  }

  .dora-chart-wrap {
    position: relative;
    height: 220px;
  }

  @media (max-width: 700px) {
    .dora-cards {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  @media (max-width: 400px) {
    .dora-cards {
      grid-template-columns: 1fr !important;
    }
  }
</style>
