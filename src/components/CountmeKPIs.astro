---
import type { WeekRecord } from '../lib/types.ts';
import Sparkline from './Sparkline.astro';

interface ImageSpec {
  key: string;        // distro key in WeekRecord.distros
  label: string;      // display label
  color: string;      // CSS color string e.g. 'var(--blue)'
}

interface Props {
  currentWeek: WeekRecord | null;
  wowGrowthPct: Record<string, number> | null;
  weekRecords?: WeekRecord[];
  images?: ImageSpec[];
}

const { currentWeek, wowGrowthPct, weekRecords = [] } = Astro.props;

// Default: original 3 image cards (backward-compat for pages that don't pass images)
const images: ImageSpec[] = Astro.props.images ?? [
  { key: 'bazzite', label: 'Bazzite', color: 'var(--blue)'   },
  { key: 'bluefin', label: 'Bluefin', color: 'var(--purple)' },
  { key: 'aurora',  label: 'Aurora',  color: 'var(--green)'  },
];

function sparklineFor(key: string): number[] {
  return weekRecords.slice(-12).map((w: WeekRecord) => w.distros?.[key] ?? 0);
}

function trendArrow(pct: number | null | undefined): string {
  if (pct == null) return '';
  if (pct > 0) return '▲';
  if (pct < 0) return '▼';
  return '→';
}
function trendClass(pct: number | null | undefined): string {
  if (pct == null) return 'trend-neutral';
  if (pct > 0) return 'trend-up';
  if (pct < 0) return 'trend-down';
  return 'trend-neutral';
}
function fmt(n: number | undefined): string {
  return (n ?? 0).toLocaleString();
}
---

<div class="hero-kpis">
  <!-- Total card -->
  <div class="kpi-card kpi-total">
    <div class="kpi-value">
      {fmt(currentWeek?.total)}
      {wowGrowthPct?.total != null && (
        <span class={`kpi-trend ${trendClass(wowGrowthPct.total)}`}>
          {trendArrow(wowGrowthPct.total)} {Math.abs(wowGrowthPct.total).toFixed(1)}%
        </span>
      )}
    </div>
    <div class="kpi-sub">/ this week</div>
    <div class="kpi-label">Total Active Devices</div>
  </div>

  <!-- Per-image cards -->
  {images.map(img => {
    const count = currentWeek?.distros?.[img.key] ?? 0;
    const wow   = wowGrowthPct?.[img.key] ?? null;
    const spark  = sparklineFor(img.key);
    const hasCount = count > 0;
    return (
      <div class="kpi-card">
        <div class="kpi-value">
          {hasCount ? fmt(count) : <span class="kpi-collecting">Collecting…</span>}
          {wow != null && hasCount && (
            <span class={`kpi-trend ${trendClass(wow)}`}>
              {trendArrow(wow)}
            </span>
          )}
        </div>
        {hasCount && <div class="kpi-sub">/ this week</div>}
        <div class="kpi-label">{img.label}</div>
        {spark.length >= 2 && spark.some(v => v > 0) && (
          <div class="kpi-sparkline">
            <Sparkline data={spark} color={img.color} label={`${img.label} 12-week trend`} />
          </div>
        )}
      </div>
    );
  })}
</div>

<style>
  .hero-kpis { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; }
  .kpi-card {
    background: var(--bg2); border: 1px solid var(--border); border-radius: 8px;
    padding: 20px 24px; flex: 1 1 160px;
    display: flex; flex-direction: column;
    transition: border-color 0.15s, background 0.15s;
  }
  .kpi-card:hover {
    border-color: var(--accent);
    background: var(--bg3);
  }
  .kpi-total {
    border-left: 3px solid var(--blue);
  }
  .kpi-value {
    font-size: 2rem; font-weight: 700; color: var(--text); line-height: 1.1;
    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
  }
  .kpi-collecting {
    font-size: 0.9rem; color: var(--muted); font-weight: 400;
  }
  .kpi-sub {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 2px;
  }
  .kpi-label { font-size: 11px; color: var(--muted); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
  .kpi-sparkline { margin-top: auto; padding-top: 10px; }
  .kpi-sparkline :global(.sparkline-wrap) {
    display: block;
    width: 100%;
    margin-left: 0;
  }
  .kpi-sparkline :global(.sparkline-wrap canvas) { height: 28px !important; }
  .kpi-trend { font-size: 0.9rem; font-weight: 600; }
  .trend-up { color: var(--green); }
  .trend-down { color: var(--red); }
  .trend-neutral { color: var(--muted); }
  @media (max-width: 600px) { .kpi-card { flex: 1 1 calc(50% - 6px); } }
</style>
