---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';
import type { WeekRecord } from '../lib/types.ts';

interface Props {
  weekRecords: WeekRecord[];
}
const { weekRecords } = Astro.props;

const DISTROS = ['bazzite', 'bluefin', 'bluefin-lts', 'aurora'];
const LABELS  = ['Bazzite', 'Bluefin', 'Bluefin LTS', 'Aurora'];

const sorted = [...weekRecords].sort((a, b) => a.week_start.localeCompare(b.week_start));
---

{weekRecords.length === 0 ? (
  <ChartCard title="Active Devices per Week" canvasId="countme-trend-chart" isEmpty emptyMsg="Collecting data…" />
) : (
  <>
    <ChartCard
      title="Active Devices per Week"
      canvasId="countme-trend-chart"
      height={300}
      rangeId="countme-range-btns"
      ranges={[{ label: '30d', value: '30' }, { label: '90d', value: '90' }, { label: 'All', value: 'all' }]}
      defaultRange="30"
    />
    <script type="application/json" id="countme-trend-data" set:html={safeJson({ sorted, DISTROS, LABELS })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { BRAND_COLOURS, getChartColors } from '../lib/chart-theme.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('countme-trend-data');
if (dataEl) {
  const { sorted, DISTROS, LABELS } = JSON.parse(dataEl.textContent!);
  const canvas = document.getElementById('countme-trend-chart') as HTMLCanvasElement;

  function getFiltered(range: string) {
    if (range === 'all') return sorted;
    const days = Number(range);
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    const cutoffStr = cutoff.toISOString().slice(0, 10);
    return sorted.filter((r: { week_start: string }) => r.week_start >= cutoffStr);
  }

  function buildDatasets(data: { distros: Record<string, number> }[]) {
    return (DISTROS as string[]).map((distro, i) => ({
      label: LABELS[i],
      data: data.map((r: { distros: Record<string, number> }) => r.distros[distro] ?? 0),
      borderColor: BRAND_COLOURS[i],
      backgroundColor: 'transparent',
      tension: 0.3,
      pointRadius: 3,
    }));
  }

  let currentRange = '30';
  let filtered = getFiltered(currentRange);
  const c = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(canvas, {
      type: 'line',
      data: {
        labels: filtered.map((r: { week_start: string }) => r.week_start),
        datasets: buildDatasets(filtered),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: { grid: { color: c.grid }, ticks: { color: c.muted, maxTicksLimit: 10 } },
          y: {
            beginAtZero: true,
            grid: { color: c.grid },
            ticks: {
              color: c.muted,
              callback: (v: number | string) =>
                Number(v) >= 1000 ? `${(Number(v) / 1000).toFixed(0)}k` : String(v),
            },
          },
        },
        plugins: { legend: { labels: { color: c.text, usePointStyle: true, boxWidth: 8 } } },
      },
    });
  } catch (e) {
    console.error('[CountmeTrendChart] Chart.js init failed:', e);
  }

  document.getElementById('countme-range-btns')?.querySelectorAll<HTMLButtonElement>('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      document.getElementById('countme-range-btns')?.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentRange = btn.dataset.range!;
      const data = getFiltered(currentRange);
      chart.data.labels = data.map((r: { week_start: string }) => r.week_start);
      chart.data.datasets = buildDatasets(data);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const colors = getChartColors();
    (chart.options.plugins!.legend!.labels as { color: string }).color = colors.text;
    chart.options.scales!.x!.ticks!.color = colors.muted;
    (chart.options.scales!.x!.grid as { color: string }).color = colors.grid;
    chart.options.scales!.y!.ticks!.color = colors.muted;
    (chart.options.scales!.y!.grid as { color: string }).color = colors.grid;
    chart.update();
  });
}
</script>
