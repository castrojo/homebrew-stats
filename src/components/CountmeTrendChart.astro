---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';
import type { WeekRecord } from '../lib/types.ts';
import { aggregateWeekRecordsToMonthEnd } from '../lib/countme.ts';

interface DistroSpec { key: string; label: string; }

interface Props {
  weekRecords: WeekRecord[];
  distros?: DistroSpec[];
}
const { weekRecords } = Astro.props;

// Default to the original 4 if not provided (backward-compat for individual image pages)
const distroSpecs: DistroSpec[] = Astro.props.distros ?? [
  { key: 'bazzite',     label: 'Bazzite'     },
  { key: 'bluefin',     label: 'Bluefin'     },
  { key: 'bluefin-lts', label: 'Bluefin LTS' },
  { key: 'aurora',      label: 'Aurora'      },
];

const DISTROS = distroSpecs.map(d => d.key);
const LABELS  = distroSpecs.map(d => d.label);

const monthly = aggregateWeekRecordsToMonthEnd(weekRecords as WeekRecord[]);
---

{weekRecords.length === 0 ? (
  <ChartCard title="Active Devices per Month" canvasId="countme-trend-chart" isEmpty emptyMsg="Collecting data..." />
) : (
  <>
    <ChartCard
      title="Active Devices per Month"
      canvasId="countme-trend-chart"
      height={300}
      rangeId="countme-range-btns"
      ranges={[{ label: '30d', value: '30' }, { label: '90d', value: '90' }, { label: '365d', value: '365' }, { label: 'All', value: 'all' }]}
      defaultRange="365"
    />
    <script type="application/json" id="countme-trend-data" set:html={safeJson({ monthly, weekly: weekRecords, DISTROS, LABELS })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { BRAND_COLOURS, getChartColors } from '../lib/chart-theme.js';
import { readChartData } from '../lib/inject.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('countme-trend-data');
if (dataEl) {
  const { monthly, weekly, DISTROS, LABELS } = readChartData<{
    monthly: { week_end: string; distros: Record<string, number> }[];
    weekly: { week_start: string; week_end: string; distros: Record<string, number> }[];
    DISTROS: string[];
    LABELS: string[];
  }>('countme-trend-data');
  const canvas = document.getElementById('countme-trend-chart') as HTMLCanvasElement;
  const rangeContainer = document.getElementById('countme-range-btns');

  const header = rangeContainer?.closest('.chart-header');
  if (header && rangeContainer) {
    const controlsRow = document.createElement('div');
    controlsRow.className = 'countme-controls-row';
    rangeContainer.replaceWith(controlsRow);
    controlsRow.appendChild(rangeContainer);

    const granularityBtns = document.createElement('div');
    granularityBtns.className = 'range-btns countme-granularity-btns';
    granularityBtns.id = 'countme-granularity-btns';
    granularityBtns.innerHTML = `
      <button class="range-btn" data-granularity="weekly">Weekly</button>
      <button class="range-btn active" data-granularity="monthly">Monthly</button>
    `;
    controlsRow.appendChild(granularityBtns);
    header.appendChild(controlsRow);
  }

  function getFiltered(range: string, granularity: 'monthly' | 'weekly') {
    const source = granularity === 'weekly' ? weekly : monthly;
    if (range === 'all') return source;
    const days = Number(range);
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    const cutoffStr = cutoff.toISOString().slice(0, 10);
    return source.filter((r: { week_start?: string; week_end: string }) =>
      (granularity === 'weekly' ? r.week_start : r.week_end) >= cutoffStr,
    );
  }

  function buildDatasets(data: { distros: Record<string, number> }[]) {
    return (DISTROS as string[]).map((distro, i) => ({
      label: LABELS[i],
      data: data.map((r: { distros: Record<string, number> }) => r.distros[distro] ?? 0),
      borderColor: BRAND_COLOURS[i],
      backgroundColor: 'transparent',
      tension: 0.3,
      pointRadius: 3,
    }));
  }

  let currentRange = '365';
  let currentGranularity: 'monthly' | 'weekly' = 'monthly';
  let filtered = getFiltered(currentRange, currentGranularity);
  const c = getChartColors();
  const getLabel = (r: { week_start?: string; week_end: string }) =>
    currentGranularity === 'weekly' ? r.week_start : r.week_end;

  let chart: Chart | undefined;
  try {
    chart = new Chart(canvas, {
      type: 'line',
      data: {
        labels: filtered.map((r: { week_start?: string; week_end: string }) => getLabel(r)),
        datasets: buildDatasets(filtered),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: { grid: { color: c.grid }, ticks: { color: c.muted, maxTicksLimit: 10 } },
          y: {
            beginAtZero: true,
            grid: { color: c.grid },
            ticks: {
              color: c.muted,
              callback: (v: number | string) =>
                Number(v) >= 1000 ? `${(Number(v) / 1000).toFixed(0)}k` : String(v),
            },
          },
        },
        plugins: { legend: { labels: { color: c.text, usePointStyle: true, boxWidth: 8 } } },
      },
    });
  } catch (e) {
    console.error('[CountmeTrendChart] Chart.js init failed:', e);
  }

  function updateChart() {
    if (!chart) return;
    const data = getFiltered(currentRange, currentGranularity);
    chart.data.labels = data.map((r: { week_start?: string; week_end: string }) =>
      currentGranularity === 'weekly' ? r.week_start : r.week_end,
    );
    chart.data.datasets = buildDatasets(data);
    chart.update();
  }

  rangeContainer?.querySelectorAll<HTMLButtonElement>('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      rangeContainer?.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentRange = btn.dataset.range!;
      updateChart();
    });
  });

  document.getElementById('countme-granularity-btns')?.querySelectorAll<HTMLButtonElement>('.range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('countme-granularity-btns')?.querySelectorAll('.range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentGranularity = btn.dataset.granularity as 'monthly' | 'weekly';
      updateChart();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const colors = getChartColors();
    (chart.options.plugins!.legend!.labels as { color: string }).color = colors.text;
    chart.options.scales!.x!.ticks!.color = colors.muted;
    (chart.options.scales!.x!.grid as { color: string }).color = colors.grid;
    chart.options.scales!.y!.ticks!.color = colors.muted;
    (chart.options.scales!.y!.grid as { color: string }).color = colors.grid;
    chart.update();
  });
}
</script>

<style>
  :global(.countme-controls-row) {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  :global(.countme-granularity-btns) {
    display: flex;
    gap: 4px;
  }

  :global(.countme-granularity-btns .range-btn) {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 11px;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  :global(.countme-granularity-btns .range-btn:hover) {
    background: var(--bg);
    color: var(--text);
  }

  :global(.countme-granularity-btns .range-btn.active) {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
</style>
