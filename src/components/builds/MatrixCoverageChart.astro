---
import ChartCard from '../ChartCard.astro';
import { safeJson } from '../../lib/inject.ts';
import type { BuildRepoMetrics, BuildDailySnapshot } from '../../lib/types.ts';

interface Props {
  repos: BuildRepoMetrics[];
  history: BuildDailySnapshot[];
}

const { repos, history } = Astro.props;
const isEmpty = repos.length === 0;

// Serialize only what the chart needs
interface MatrixPayload {
  repoNames: string[];
  activeCounts: number[];
}

const payload: MatrixPayload = {
  repoNames: repos.map(r => r.repo),
  activeCounts: repos.map(r => r.streams.filter(s => s.total_runs_7d > 0).length),
};
---

<ChartCard
  title="Matrix Coverage — Active vs Expected Streams"
  canvasId="matrix-coverage-chart"
  height={240}
  isEmpty={isEmpty}
  emptyMsg="No build data yet."
/>

{!isEmpty && (
  <script type="application/json" id="matrix-coverage-data" set:html={safeJson(payload)}></script>
)}

<script>
import '../../lib/chart-registry.js';
import { Chart } from 'chart.js';
import { BRAND_COLOURS, getChartColors, applyTheme } from '../../lib/chart-theme.js';
import { readChartData } from '../../lib/inject.js';

const EXPECTED: Record<string, number> = {
  'bluefin': 3,
  'bluefin-lts': 7,
  'common': 1,
  'dakota': 1,
  'iso': 3,
  'finpilot': 1,
  'testhub': 1,
};

interface MatrixPayload {
  repoNames: string[];
  activeCounts: number[];
}

const dataEl = document.getElementById('matrix-coverage-data');
if (dataEl) {
  const payload = readChartData<MatrixPayload>('matrix-coverage-data');
  const { repoNames, activeCounts } = payload;

  const expectedCounts = repoNames.map(name => EXPECTED[name] ?? 1);
  const activeColors = repoNames.map((name, i) => {
    const exp = EXPECTED[name] ?? 1;
    return activeCounts[i] >= exp ? BRAND_COLOURS[2] : BRAND_COLOURS[4];
  });

  const canvas = document.getElementById('matrix-coverage-chart') as HTMLCanvasElement | null;
  if (canvas) {
    const colors = getChartColors();
    let chart: Chart | undefined;
    try {
      chart = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: repoNames,
          datasets: [
            {
              label: 'Expected Streams',
              data: expectedCounts,
              backgroundColor: BRAND_COLOURS[5],
              borderRadius: 3,
            },
            {
              label: 'Active (7d)',
              data: activeCounts,
              backgroundColor: activeColors,
              borderRadius: 3,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              labels: {
                color: colors.text,
                font: { size: 11 },
                usePointStyle: true,
                boxWidth: 8,
              },
            },
          },
          scales: {
            x: {
              ticks: { color: colors.muted, font: { size: 10 } },
              grid: { color: colors.grid },
            },
            y: {
              beginAtZero: true,
              ticks: {
                color: colors.muted,
                font: { size: 10 },
                stepSize: 1,
              },
              grid: { color: colors.grid },
            },
          },
        },
      });
    } catch (e) {
      console.error('[MatrixCoverageChart] Chart init failed:', e);
    }

    window.addEventListener('themechange', () => {
      if (!chart) return;
      applyTheme(chart);
    });
  }
}
</script>
