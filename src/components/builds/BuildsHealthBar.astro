---
import type { PipelineSummary } from '../../lib/types.ts';

interface Props {
  summary: PipelineSummary;
  doraLevel: string;
}

const { summary, doraLevel } = Astro.props;

function healthIcon(status: string): string {
  switch (status) {
    case 'healthy':  return '🟢';
    case 'degraded': return '🟡';
    case 'failing':  return '🔴';
    default:         return '⚪';
  }
}

function healthLabel(status: string): string {
  switch (status) {
    case 'healthy':  return 'Healthy';
    case 'degraded': return 'Degraded';
    case 'failing':  return 'Failing';
    default:         return 'Unknown';
  }
}

function doraColor(level: string): string {
  switch (level) {
    case 'elite':  return 'var(--blue)';
    case 'high':   return 'var(--green)';
    case 'medium': return 'var(--yellow)';
    case 'low':    return 'var(--red)';
    default:       return 'var(--muted)';
  }
}

const statusLabel = `${healthIcon(summary.health_status)} ${healthLabel(summary.health_status)}`;
const successRate = summary.overall_success_rate_7d.toFixed(1) + '%';
const builds7d = summary.total_builds_7d.toLocaleString();
const medianDuration = summary.p50_duration_min.toFixed(0) + 'm';
const p95Duration = summary.p95_duration_min.toFixed(0) + 'm';
const doraLevelDisplay = doraLevel.charAt(0).toUpperCase() + doraLevel.slice(1);
---

<div class="kpi-strip">
  <!-- Pipeline Status -->
  <div class="kpi-card" data-status={summary.health_status}>
    <div class="kpi-label">Pipeline Status</div>
    <div class="kpi-value status-value" data-status={summary.health_status}>{statusLabel}</div>
  </div>

  <!-- Success Rate (7d) -->
  <div class="kpi-card">
    <div class="kpi-label">Success Rate (7d)</div>
    <div class="kpi-value">{successRate}</div>
  </div>

  <!-- Builds (7d) -->
  <div class="kpi-card">
    <div class="kpi-label">Builds (7d)</div>
    <div class="kpi-value">{builds7d}</div>
  </div>

  <!-- Median Duration -->
  <div class="kpi-card">
    <div class="kpi-label">Median Duration</div>
    <div class="kpi-value">{medianDuration}</div>
    <div class="kpi-sub">P95: {p95Duration}</div>
  </div>

  <!-- DORA Level -->
  <div class="kpi-card">
    <div class="kpi-label">DORA Level</div>
    <div class="kpi-value">
      <span class="dora-badge" style={`background:${doraColor(doraLevel)}`}>{doraLevelDisplay}</span>
    </div>
  </div>
</div>

<style>
  .kpi-strip {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .kpi-card {
    flex: 1;
    min-width: 150px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
  }

  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .kpi-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  .kpi-sub {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* Status coloring */
  .status-value[data-status='healthy']  { color: var(--green); }
  .status-value[data-status='degraded'] { color: var(--yellow); }
  .status-value[data-status='failing']  { color: var(--red); }
  .status-value[data-status='unknown']  { color: var(--muted); }

  .dora-badge {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    text-transform: capitalize;
  }

  @media (max-width: 700px) {
    .kpi-card { flex: 1 1 calc(50% - 0.5rem); }
  }
</style>
