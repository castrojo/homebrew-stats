---
import ChartCard from '../ChartCard.astro';
import { safeJson } from '../../lib/inject.ts';
import type { FailureCategory } from '../../lib/types.ts';

interface Props {
  breakdown: FailureCategory[];
  mttr: number; // minutes
  mtbf: number; // hours
}

const { breakdown, mttr, mtbf } = Astro.props;

function formatMttr(minutes: number): string {
  return minutes < 60 ? `${minutes.toFixed(0)}m` : `${(minutes / 60).toFixed(1)}h`;
}

function mttrColorVar(minutes: number): string {
  if (minutes < 60) return 'var(--green)';
  if (minutes <= 240) return 'var(--yellow)';
  return 'var(--red)';
}

function mtbfColorVar(hours: number): string {
  if (hours > 24) return 'var(--green)';
  if (hours >= 8) return 'var(--yellow)';
  return 'var(--red)';
}

const mttrDisplay = formatMttr(mttr);
const mttrCol = mttrColorVar(mttr);
const mtbfDisplay = `${mtbf.toFixed(1)}h`;
const mtbfCol = mtbfColorVar(mtbf);
---

<div class="failure-analysis-grid">
  <ChartCard
    title="Failure Category Breakdown"
    canvasId="failure-doughnut"
    height={260}
    isEmpty={breakdown.length === 0}
    emptyMsg="Collecting data…"
  />

  <div class="mttr-mtbf-cards">
    <div class="kpi-card">
      <div class="kpi-label">MTTR</div>
      <div class="kpi-value" style={`color:${mttrCol}`}>{mttrDisplay}</div>
      <div class="kpi-sub">Mean Time to Recovery</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">MTBF</div>
      <div class="kpi-value" style={`color:${mtbfCol}`}>{mtbfDisplay}</div>
      <div class="kpi-sub">Mean Time Between Failures</div>
    </div>
  </div>
</div>

{breakdown.length > 0 && (
  <script type="application/json" id="failure-analysis-data" set:html={safeJson({ breakdown })}></script>
)}

{breakdown.length > 0 && (
<script>
  import '../../lib/chart-registry.js';
  import { readChartData } from '../../lib/inject.js';
  import { BRAND_COLOURS, getChartColors } from '../../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { breakdown } = readChartData<{
    breakdown: { category: string; count: number; pct: number }[];
  }>('failure-analysis-data');

  // Assign colors positionally so every slice is distinct regardless of label content.
  // BRAND_COLOURS has 10 entries — more than enough for any realistic failure category list.
  const sliceColors = breakdown.map((_, i) => BRAND_COLOURS[i % BRAND_COLOURS.length]);

  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('failure-doughnut') as HTMLCanvasElement, {
      type: 'doughnut',
      data: {
        labels: breakdown.map(f => f.category),
        datasets: [
          {
            data: breakdown.map(f => f.count),
            backgroundColor: sliceColors,
            borderColor: 'transparent',
            borderWidth: 1,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'right',
            labels: { color: colors.text, font: { size: 12 } },
          },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const item = breakdown[ctx.dataIndex];
                return ` ${item.category}: ${item.count} (${item.pct.toFixed(1)}%)`;
              },
            },
          },
        },
      },
    });
  } catch (e) {
    console.error('[FailureAnalysisChart] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const c = getChartColors();
    if (chart.options.plugins?.legend?.labels) {
      chart.options.plugins.legend.labels.color = c.text;
    }
    chart.update();
  });
</script>
)}

<style>
  .failure-analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 20px;
  }

  .mttr-mtbf-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .kpi-card {
    flex: 1;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .kpi-value {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .kpi-sub {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  @media (max-width: 700px) {
    .failure-analysis-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
