---
import type { BuildRepoMetrics } from '../../lib/types.ts';
import { rateColor } from '../../lib/build-utils.ts';

interface Props {
  repos: BuildRepoMetrics[];
}

const { repos } = Astro.props;

// Helpers
function lastConclusionIcon(repo: BuildRepoMetrics): string {
  const streams = repo.streams ?? [];
  if (!streams.length) return '⚪';
  // Find the most recent stream by last_run_at
  const sorted = [...streams].sort(
    (a, b) => new Date(b.last_run_at).getTime() - new Date(a.last_run_at).getTime()
  );
  const latest = sorted[0];
  if (latest.last_conclusion === 'success') return '🟢';
  if (!latest.last_conclusion) return '⚪';
  return '🔴';
}

function lastConclusionLabel(repo: BuildRepoMetrics): string {
  const streams = repo.streams ?? [];
  if (!streams.length) return 'No data';
  const sorted = [...streams].sort(
    (a, b) => new Date(b.last_run_at).getTime() - new Date(a.last_run_at).getTime()
  );
  return sorted[0].last_conclusion || 'unknown';
}
---

<!-- Section A: Comparison Table -->
<div class="chart-card">
  <div class="chart-header">
    <div class="chart-title">Builder Comparison — All Repos</div>
  </div>

  {repos.length === 0 ? (
    <p class="chart-empty">Collecting data…</p>
  ) : (
    <div class="table-wrap">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Repo</th>
            <th>Success Rate 7d</th>
            <th>Success Rate 30d</th>
            <th>Avg Duration</th>
            <th>Total Runs (7d)</th>
            <th>Last Stream Status</th>
          </tr>
        </thead>
        <tbody>
          {repos.map(repo => (
            <tr>
              <td class="repo-name">{repo.repo}</td>
              <td>
                <span class="rate-badge" style={`color: ${rateColor(repo.success_rate_7d)}`}>
                  {repo.success_rate_7d.toFixed(1)}%
                </span>
              </td>
              <td>
                <span class="rate-badge" style={`color: ${rateColor(repo.success_rate_30d)}`}>
                  {repo.success_rate_30d.toFixed(1)}%
                </span>
              </td>
              <td>{repo.avg_duration_min.toFixed(0)}m</td>
              <td>{repo.total_runs_7d.toLocaleString()}</td>
              <td class="status-cell">
                <span class="status-badge">
                  {lastConclusionIcon(repo)} {lastConclusionLabel(repo)}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</div>

<style>
  .chart-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .chart-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .chart-empty {
    text-align: center;
    color: var(--muted);
    padding: 3rem 0;
    font-size: 14px;
  }

  /* Table styles */
  .table-wrap {
    overflow-x: auto;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .comparison-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 12px;
    border-bottom: 1px solid var(--border);
  }

  .comparison-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table tbody tr:hover {
    background: var(--bg);
  }

  .repo-name {
    font-weight: 600;
    font-family: monospace;
  }

  .rate-badge {
    font-weight: 700;
  }

  .status-cell {
    white-space: nowrap;
  }

  .status-badge {
    font-size: 12px;
    color: var(--muted);
  }
</style>
