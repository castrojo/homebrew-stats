---
interface TapSnapshot {
  uniques: number;
  count: number;
  downloads?: Record<string, number>;
}

interface DaySnapshot {
  date: string;
  taps: Record<string, TapSnapshot>;
}

interface Props {
  history: DaySnapshot[];
  tapNames: string[];
}

const { history, tapNames } = Astro.props;

// Only include snapshots where at least one tap has download data.
const relevant = history.filter(d => tapNames.some(t => d.taps[t]?.downloads));

// Two distinct colours — blue for stable, purple for experimental.
const COLOURS = ['#388bfd', '#a371f7'];

// Short display names for chart legend.
const displayNames: Record<string, string> = {
  'ublue-os/homebrew-tap': 'Stable',
  'ublue-os/homebrew-experimental-tap': 'Experimental',
};
---

{relevant.length < 2 ? (
  <p class="chart-empty">Not enough history yet — charts will appear after a few daily syncs.</p>
) : (
  <div class="comparison-card">
    <div class="comparison-header">
      <div class="range-btns" id="comparison-range-btns">
        <button class="range-btn active" data-range="30">30d</button>
        <button class="range-btn" data-range="90">90d</button>
        <button class="range-btn" data-range="all">All</button>
      </div>
    </div>
    <div class="chart-wrap">
      <canvas id="tap-comparison-chart"></canvas>
    </div>
  </div>
  <script type="application/json" id="comparison-data">{JSON.stringify({ relevant, tapNames, COLOURS, displayNames })}</script>
)}

<script>
  import Chart from 'chart.js/auto';

  const dataEl = document.getElementById('comparison-data');
  if (!dataEl) throw new Error('comparison-data not found');

  const { relevant: allRelevant, tapNames, COLOURS, displayNames } = JSON.parse(dataEl.textContent!);

  function getCSSVar(name) {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }
  function getChartColors() {
    return {
      text: getCSSVar('--text'),
      muted: getCSSVar('--muted'),
      grid: getCSSVar('--border'),
    };
  }

  function getTapTotal(snapshot, tapName) {
    const downloads = snapshot.taps[tapName]?.downloads ?? {};
    return Object.values(downloads).reduce((s, n) => s + n, 0);
  }

  function buildDatasets(data) {
    return tapNames.map((name, i) => ({
      label: displayNames[name] ?? name,
      data: data.map(d => getTapTotal(d, name)),
      borderColor: COLOURS[i % COLOURS.length],
      backgroundColor: COLOURS[i % COLOURS.length] + '22',
      fill: false,
      tension: 0.3,
      pointRadius: data.length < 15 ? 4 : 2,
      spanGaps: true,
    }));
  }

  function getWindow(range) {
    if (range === '30') return allRelevant.slice(-30);
    if (range === '90') return allRelevant.slice(-90);
    return allRelevant;
  }

  let current = getWindow('30');
  const colors = getChartColors();

  const chart = new Chart(document.getElementById('tap-comparison-chart'), {
    type: 'line',
    data: {
      labels: current.map(d => d.date),
      datasets: buildDatasets(current),
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          labels: { color: colors.text, font: { size: 12 } },
        },
        tooltip: {
          callbacks: {
            label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'} downloads (30d window)`,
          },
        },
      },
      scales: {
        x: {
          ticks: { color: colors.muted, font: { size: 11 }, maxRotation: 45 },
          grid: { color: colors.grid },
        },
        y: {
          beginAtZero: true,
          ticks: {
            color: colors.muted,
            font: { size: 11 },
            callback: v => Number(v).toLocaleString(),
          },
          grid: { color: colors.grid },
          title: {
            display: true,
            text: 'Downloads (30d window)',
            color: colors.muted,
            font: { size: 11 },
          },
        },
      },
    },
  });

  // Time range selector
  document.querySelectorAll('#comparison-range-btns .range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#comparison-range-btns .range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const data = getWindow(btn.dataset.range);
      chart.data.labels = data.map(d => d.date);
      chart.data.datasets = buildDatasets(data);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    const c = getChartColors();
    chart.options.plugins.legend.labels.color = c.text;
    chart.options.scales.x.ticks.color = c.muted;
    chart.options.scales.x.grid.color = c.grid;
    chart.options.scales.y.ticks.color = c.muted;
    chart.options.scales.y.grid.color = c.grid;
    chart.options.scales.y.title.color = c.muted;
    chart.update();
  });
</script>

<style>
  .chart-empty {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 16px;
  }

  .comparison-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
    margin-bottom: 32px;
  }

  .comparison-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
  }

  .chart-wrap {
    max-height: 320px;
  }

  .range-btns {
    display: flex;
    gap: 4px;
  }

  .range-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 11px;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .range-btn:hover {
    background: var(--bg);
    color: var(--text);
  }

  .range-btn.active {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
</style>
