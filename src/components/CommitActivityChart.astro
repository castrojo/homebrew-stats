---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface RepoStats {
  name: string;
  weekly_commits_52w: number[];
  commits_30d: number;
  commits_60d?: number;
  commits_365d?: number;
}

interface Props {
  repos: RepoStats[];
}

const { repos } = Astro.props;
---

<ChartCard
  title="Commit Activity by Repository"
  canvasId="commit-activity-chart"
  height={260}
  rangeId="commit-activity-range-btns"
  ranges={[{ label: '30d', value: '30d' }, { label: '60d', value: '60d' }, { label: '365d', value: '365d' }]}
  defaultRange="30d"
/>
<script type="application/json" id="commit-activity-data" set:html={safeJson({ repos })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { repos } = readChartData<{
    repos: {
      name: string;
      weekly_commits_52w: number[];
      commits_30d: number;
      commits_60d?: number;
      commits_365d?: number;
    }[];
  }>('commit-activity-data');

  const weeks = ['Week -4', 'Week -3', 'Week -2', 'Last Week'];

  // rangeData[range][repoIndex] = commit count for that range
  const rangeData: Record<string, number[]> = {
    '30d': repos.map(r => r.commits_30d),
    '60d': repos.map(r => r.commits_60d ?? Math.round(r.commits_30d * 2)),
    '365d': repos.map(r => r.commits_365d ?? Math.round(r.commits_30d * 10)),
  };

  const datasets = repos.map((repo, i) => ({
    label: repo.name,
    data: repo.weekly_commits_52w.slice(-4),
    backgroundColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
    borderColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
    borderWidth: 1,
  }));

  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('commit-activity-chart') as HTMLCanvasElement, {
      type: 'bar',
      data: { labels: weeks, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: colors.text, font: { size: 12 } } },
        },
        scales: {
          x: {
            stacked: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
          },
          y: {
            stacked: true,
            beginAtZero: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
            title: { display: true, text: 'Commits', color: colors.muted, font: { size: 11 } },
          },
        },
      },
    });
  } catch (e) {
    console.error('[CommitActivityChart] Chart.js init failed:', e);
  }

  document.querySelectorAll('#commit-activity-range-btns [data-range]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      const range = (btn as HTMLElement).dataset.range!;
      document.querySelectorAll('#commit-activity-range-btns [data-range]').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      // Update each dataset with a single total per repo for that range
      chart.data.labels = [range];
      chart.data.datasets.forEach((ds, i) => {
        ds.data = [rangeData[range][i]];
      });
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
