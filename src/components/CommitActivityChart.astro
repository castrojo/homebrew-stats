---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface RepoStats {
  name: string;
  weekly_commits_52w: number[];
}

interface Props {
  repos: RepoStats[];
}

const { repos } = Astro.props;
---

<ChartCard
  title="Commit Activity by Repository (Last 4 Weeks)"
  canvasId="commit-activity-chart"
  height={260}
/>
<script type="application/json" id="commit-activity-data" set:html={safeJson({ repos })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { repos } = readChartData<{
    repos: { name: string; weekly_commits_52w: number[] }[];
  }>('commit-activity-data');

  const weeks = ['Week -4', 'Week -3', 'Week -2', 'Last Week'];

  const datasets = repos.map((repo, i) => {
    const last4 = repo.weekly_commits_52w.slice(-4);
    return {
      label: repo.name,
      data: last4,
      backgroundColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
      borderColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
      borderWidth: 1,
    };
  });

  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('commit-activity-chart') as HTMLCanvasElement, {
      type: 'bar',
      data: { labels: weeks, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: colors.text, font: { size: 12 } } },
        },
        scales: {
          x: {
            stacked: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
          },
          y: {
            stacked: true,
            beginAtZero: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
            title: { display: true, text: 'Commits', color: colors.muted, font: { size: 11 } },
          },
        },
      },
    });
  } catch (e) {
    console.error('[CommitActivityChart] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
