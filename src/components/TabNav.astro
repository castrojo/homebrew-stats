---
interface Props { activeTab: 'homebrew' | 'testhub' | 'overall' | 'contributors'; }
const { activeTab } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<nav class="tab-nav">
  <a href={`${base}/`}         data-astro-prefetch class:list={['tab', { active: activeTab === 'homebrew' }]}>🍺 Homebrew</a>
  <a href={`${base}/testhub/`} data-astro-prefetch class:list={['tab', { active: activeTab === 'testhub' }]}>🧪 Testhub</a>
  <a href={`${base}/overall/`}       data-astro-prefetch class:list={['tab', { active: activeTab === 'overall'       }]}>🌐 Overall</a>
  <a href={`${base}/contributors/`}  data-astro-prefetch class:list={['tab', { active: activeTab === 'contributors'  }]}>👥 Contributors</a>
</nav>
<style>
.tab-nav {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2rem;
}
.tab {
  padding: 0.75rem 1.5rem;
  text-decoration: none;
  color: var(--muted);
  border-bottom: 2px solid transparent;
  font-size: 0.9rem;
  transition: color 0.15s, border-color 0.15s;
}
.tab:hover { color: var(--text); }
.tab.active {
  color: var(--blue);
  border-bottom-color: var(--blue);
}
</style>
