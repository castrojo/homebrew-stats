---
interface Props { activeTab: 'homebrew' | 'testhub' | 'overall' | 'contributors' | 'builds' | 'aurora-builds' | 'bazzite-builds' | 'universal-blue' | 'ucore' | 'secureblue' | 'wayblue' | 'bluebuildos' | 'zirconium' | 'bootcrew'; }
const { activeTab } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<nav class="tab-nav">
  <a href={`${base}/overall/`}           data-astro-prefetch class:list={['tab', { active: activeTab === 'overall'          }]}>bootc</a>
  <a href={`${base}/`}                   data-astro-prefetch class:list={['tab', { active: activeTab === 'homebrew'         }]}>Homebrew</a>
  <a href={`${base}/testhub/`}           data-astro-prefetch class:list={['tab', { active: activeTab === 'testhub'          }]}>Testhub</a>
  <a href={`${base}/contributors/`}      data-astro-prefetch class:list={['tab', { active: activeTab === 'contributors'     }]}>Contributors</a>
  <a href={`${base}/universal-blue/`}    data-astro-prefetch class:list={['tab', { active: activeTab === 'universal-blue'   }]}>ublue-os</a>
  <a href={`${base}/builds/`}            data-astro-prefetch class:list={['tab', { active: activeTab === 'builds'           }]}>Bluefin</a>
  <a href={`${base}/aurora-builds/`}     data-astro-prefetch class:list={['tab', { active: activeTab === 'aurora-builds'   }]}>Aurora</a>
  <a href={`${base}/bazzite-builds/`}    data-astro-prefetch class:list={['tab', { active: activeTab === 'bazzite-builds'  }]}>Bazzite</a>
  <a href={`${base}/ucore/`}             data-astro-prefetch class:list={['tab', { active: activeTab === 'ucore'            }]}>uCore</a>
  <a href={`${base}/secureblue/`}        data-astro-prefetch class:list={['tab', { active: activeTab === 'secureblue'       }]}>secureblue</a>
  <a href={`${base}/wayblue/`}           data-astro-prefetch class:list={['tab', { active: activeTab === 'wayblue'          }]}>wayblue</a>
  <a href={`${base}/bluebuildos/`}       data-astro-prefetch class:list={['tab', { active: activeTab === 'bluebuildos'      }]}>BlueBuildOS</a>
  <a href={`${base}/zirconium/`}         data-astro-prefetch class:list={['tab', { active: activeTab === 'zirconium'         }]}>Zirconium</a>
  <a href={`${base}/bootcrew/`}          data-astro-prefetch class:list={['tab', { active: activeTab === 'bootcrew'          }]}>bootcrew</a>
</nav>
<style>
.tab-nav {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2rem;
}
.tab {
  padding: 0.75rem 1.5rem;
  text-decoration: none;
  color: var(--muted);
  border-bottom: 2px solid transparent;
  font-size: 0.9rem;
  transition: color 0.15s, border-color 0.15s;
}
.tab:hover { color: var(--text); }
.tab.active {
  color: var(--blue);
  border-bottom-color: var(--blue);
}
</style>
