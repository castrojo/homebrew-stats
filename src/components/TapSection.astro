---
import DownloadsChart from './DownloadsChart.astro';

interface Package {
  name: string;
  type: string;
  version?: string;
  latest_version?: string;
  is_stale: boolean;
  freshness_known: boolean;
  downloads: number;
  description?: string;
  homepage?: string;
}

interface Traffic {
  count: number;
  uniques: number;
  window: string;
}

interface TapSnapshot {
  uniques: number;
  count: number;
  downloads?: Record<string, number>;
}

interface DaySnapshot {
  date: string;
  taps: Record<string, TapSnapshot>;
}

interface Props {
  name: string;
  url: string;
  traffic?: Traffic;
  packages: Package[];
  history: DaySnapshot[];
}

const { name, url, traffic, packages, history } = Astro.props;

const sorted = [...packages].sort((a, b) => {
  if (a.type !== b.type) return a.type < b.type ? -1 : 1; // cask before formula
  return (b.downloads ?? 0) - (a.downloads ?? 0);
});

const casks = sorted.filter(p => p.type === 'cask');
const formulas = sorted.filter(p => p.type === 'formula');
---

<div class="tap-section">
  <div class="tap-header">
    <h2><a href={url}>🍺 {name}</a></h2>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value">{packages.length}</div>
      <div class="stat-label">Packages</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{casks.length}</div>
      <div class="stat-label">Casks</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{formulas.length}</div>
      <div class="stat-label">Formulas</div>
    </div>
    {traffic ? (
      <div class="stat-card stat-highlight">
        <div class="stat-value">{traffic.uniques.toLocaleString()}</div>
        <div class="stat-label">Unique Tappers ({traffic.window})</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{traffic.count.toLocaleString()}</div>
        <div class="stat-label">Total Taps ({traffic.window})</div>
      </div>
    ) : (
      <div class="stat-card stat-muted">
        <div class="stat-value">—</div>
        <div class="stat-label">Traffic unavailable</div>
      </div>
    )}
    <div class="stat-card stat-current">
      <div class="stat-value">{packages.filter(p => p.freshness_known && !p.is_stale).length}</div>
      <div class="stat-label">Up to Date</div>
    </div>
    <div class="stat-card stat-stale">
      <div class="stat-value">{packages.filter(p => p.is_stale).length}</div>
      <div class="stat-label">Stale</div>
    </div>
  </div>

  <DownloadsChart tapName={name} history={history} />

  <table>
    <thead>
      <tr>
        <th>Package</th>
        <th>Type</th>
        <th>Version</th>
        <th>Latest</th>
        <th>Downloads</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {sorted.map(pkg => (
        <tr>
          <td>
            <div class="pkg-name">
              {pkg.homepage
                ? <a href={pkg.homepage}>{pkg.name}</a>
                : pkg.name}
            </div>
          </td>
          <td><span class={`badge badge-${pkg.type}`}>{pkg.type}</span></td>
          <td><span class="version">{pkg.version ?? '—'}</span></td>
          <td>
            <span class={`version${pkg.is_stale ? ' version-stale' : ''}`}>
              {pkg.latest_version ?? '—'}
            </span>
          </td>
          <td>
            {pkg.downloads > 0
              ? <span class="downloads">{pkg.downloads.toLocaleString()}</span>
              : <span class="muted">—</span>}
          </td>
          <td class="pkg-desc">{pkg.description ?? ''}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .tap-section { margin-bottom: 48px; }

  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
    min-width: 120px;
    flex: 1;
  }

  .stat-value {
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .stat-highlight { border-color: var(--blue); }
  .stat-highlight .stat-value { color: var(--blue); }
  .stat-current .stat-value { color: var(--green); }
  .stat-stale .stat-value { color: var(--yellow); }
  .stat-muted .stat-value { color: var(--muted); }

  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    font-size: 13px;
  }

  th, td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  th {
    background: var(--bg);
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(48, 54, 61, 0.5); }

  .pkg-name a { color: var(--text); font-weight: 500; }
  .pkg-name a:hover { color: var(--link); }
  .pkg-desc { color: var(--muted); max-width: 340px; }

  .version { font-family: 'SF Mono', Consolas, monospace; font-size: 12px; }
  .version-stale { color: var(--yellow); }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }

  .badge-cask    { background: rgba(88,166,255,0.15); color: #58a6ff; border: 1px solid rgba(88,166,255,0.3); }
  .badge-formula { background: rgba(163,113,247,0.15); color: #a371f7; border: 1px solid rgba(163,113,247,0.3); }

  .downloads { font-family: 'SF Mono', Consolas, monospace; font-size: 12px; color: var(--text); }
  .muted { color: var(--muted); }
</style>
