---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface DaySnapshot {
  date: string;
  build_counts: { app: string; passed: number; failed: number; total: number }[] | null;
}

interface Props {
  history: DaySnapshot[];
}
const { history } = Astro.props;

const series = [...history]
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(-30)
  .map((snapshot) => {
    const counts = snapshot.build_counts ?? [];
    const passed = counts.reduce((sum, item) => sum + (item.passed ?? 0), 0);
    const failed = counts.reduce((sum, item) => sum + (item.failed ?? 0), 0);
    return {
      date: snapshot.date,
      passed,
      failed,
    };
  });
---

{series.length === 0 ? (
  <ChartCard title="Build Outcomes (Last 30 Snapshots)" canvasId="testhub-build-chart" isEmpty emptyMsg="Collecting data…" />
) : (
  <>
    <ChartCard
      title="Build Outcomes (Last 30 Snapshots)"
      canvasId="testhub-build-chart"
      height={300}
    />
    <script type="application/json" id="testhub-build-data" set:html={safeJson({ series })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { getChartColors } from '../lib/chart-theme.js';
import { readChartData } from '../lib/inject.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('testhub-build-data');
if (dataEl) {
  const { series } = readChartData<{
    series: { date: string; passed: number; failed: number }[]
  }>('testhub-build-data');
  const canvas = document.getElementById('testhub-build-chart') as HTMLCanvasElement;
  const c = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: series.map((s) => s.date),
        datasets: [
          {
            label: 'Passed',
            data: series.map((s) => s.passed),
            backgroundColor: '#24a148',
            borderColor: '#24a148',
            borderWidth: 1,
            borderRadius: 4,
            borderSkipped: false,
            stack: 'builds',
          },
          {
            label: 'Failed',
            data: series.map((s) => s.failed),
            backgroundColor: '#fa4d56',
            borderColor: '#fa4d56',
            borderWidth: 1,
            borderRadius: 4,
            borderSkipped: false,
            stack: 'builds',
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            type: 'category',
            stacked: true,
            grid: { color: c.grid },
            ticks: { color: c.muted, maxTicksLimit: 8 },
          },
          y: {
            beginAtZero: true,
            stacked: true,
            grid: { color: c.grid },
            ticks: { color: c.muted },
          },
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              footer: (items: { parsed: { y: number } }[]) => {
                const total = items.reduce((sum, item) => sum + item.parsed.y, 0);
                return `Total: ${total}`;
              },
            },
          },
        },
      },
    });
  } catch (e) {
    console.error('[TesthubBuildChart] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const colors = getChartColors();
    chart.options.scales!.x!.ticks!.color = colors.muted;
    (chart.options.scales!.x!.grid as { color: string }).color = colors.grid;
    chart.options.scales!.y!.ticks!.color = colors.muted;
    (chart.options.scales!.y!.grid as { color: string }).color = colors.grid;
    chart.update('none');
  });
}
</script>
