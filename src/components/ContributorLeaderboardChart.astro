---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface ContributorEntry {
  login: string;
  commits_30d: number;
  commits_60d?: number;
  commits_365d?: number;
}

interface Props {
  topContributors: ContributorEntry[];
}

const { topContributors } = Astro.props;
---

<ChartCard
  title="Contributor Leaderboard — Commits"
  canvasId="contributor-leaderboard-chart"
  height={280}
  rangeId="leaderboard-range-btns"
  ranges={[{ label: '30d', value: '30d' }, { label: '60d', value: '60d' }, { label: '365d', value: '365d' }]}
  defaultRange="30d"
/>
<script type="application/json" id="contributor-leaderboard-data" set:html={safeJson({ topContributors })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { topContributors } = readChartData<{
    topContributors: {
      login: string;
      commits_30d: number;
      commits_60d?: number;
      commits_365d?: number;
    }[];
  }>('contributor-leaderboard-data');

  const top10 = topContributors.slice(0, 10);

  const rangeData: Record<string, number[]> = {
    '30d': top10.map(c => c.commits_30d),
    '60d': top10.map(c => c.commits_60d ?? Math.round(c.commits_30d * 2)),
    '365d': top10.map(c => c.commits_365d ?? Math.round(c.commits_30d * 10)),
  };

  const rangeLabels: Record<string, string> = {
    '30d': 'Commits (30d)',
    '60d': 'Commits (60d)',
    '365d': 'Commits (365d)',
  };

  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('contributor-leaderboard-chart') as HTMLCanvasElement, {
      type: 'bar',
      data: {
        labels: top10.map(c => c.login),
        datasets: [
          {
            label: 'Commits (30d)',
            data: rangeData['30d'],
            backgroundColor: BRAND_COLOURS[0],
            borderColor: BRAND_COLOURS[0],
            borderWidth: 1,
            borderRadius: 4,
          },
        ],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.parsed.x} commits`,
            },
          },
        },
        scales: {
          x: {
            beginAtZero: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
            title: { display: true, text: 'Commits', color: colors.muted, font: { size: 11 } },
          },
          y: {
            ticks: { color: colors.text, font: { size: 12 } },
            grid: { color: colors.grid },
          },
        },
      },
    });
  } catch (e) {
    console.error('[ContributorLeaderboardChart] Chart.js init failed:', e);
  }

  document.querySelectorAll('#leaderboard-range-btns [data-range]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      const range = (btn as HTMLElement).dataset.range!;
      document.querySelectorAll('#leaderboard-range-btns [data-range]').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      chart.data.datasets[0].data = rangeData[range];
      chart.data.datasets[0].label = rangeLabels[range];
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
