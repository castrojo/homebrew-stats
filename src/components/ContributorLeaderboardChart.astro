---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface ContributorEntry {
  login: string;
  commits_30d: number;
}

interface Props {
  topContributors: ContributorEntry[];
}

const { topContributors } = Astro.props;
---

<ChartCard
  title="Contributor Leaderboard — Commits (30d)"
  canvasId="contributor-leaderboard-chart"
  height={280}
/>
<script type="application/json" id="contributor-leaderboard-data" set:html={safeJson({ topContributors })}></script>

<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { topContributors } = readChartData<{
    topContributors: { login: string; commits_30d: number }[];
  }>('contributor-leaderboard-data');

  const top10 = topContributors.slice(0, 10);
  const colors = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('contributor-leaderboard-chart') as HTMLCanvasElement, {
      type: 'bar',
      data: {
        labels: top10.map(c => c.login),
        datasets: [
          {
            label: 'Commits (30d)',
            data: top10.map(c => c.commits_30d),
            backgroundColor: BRAND_COLOURS[0],
            borderColor: BRAND_COLOURS[0],
            borderWidth: 1,
            borderRadius: 4,
          },
        ],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.parsed.x} commits`,
            },
          },
        },
        scales: {
          x: {
            beginAtZero: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
            title: { display: true, text: 'Commits', color: colors.muted, font: { size: 11 } },
          },
          y: {
            ticks: { color: colors.text, font: { size: 12 } },
            grid: { color: colors.grid },
          },
        },
      },
    });
  } catch (e) {
    console.error('[ContributorLeaderboardChart] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
