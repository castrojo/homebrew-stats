---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface Props {
  osVersionDist: Record<string, Record<string, number>>;
}
const { osVersionDist } = Astro.props;

const DISTRO_ORDER = ['Bazzite', 'Bluefin', 'Bluefin LTS', 'Aurora'];

const allVersions = Array.from(
  new Set(
    Object.values(osVersionDist).flatMap(versions => Object.keys(versions))
  )
).sort((a, b) => Number(a) - Number(b));

const hasData = Object.keys(osVersionDist).length > 0 && allVersions.length > 0;

// Blue-family palette: one shade per Fedora version (older → darker, newer → lighter).
const FEDORA_VERSION_PALETTE = [
  '#1565c0', '#1976d2', '#388bfd', '#64b5f6', '#90caf9', '#bbdefb',
];
---

{!hasData ? (
  <ChartCard
    title="Popular `bootc` Operating System Images"
    canvasId="fedora-version-chart"
    isEmpty
    emptyMsg="Collecting data…"
  />
) : (
  <>
    <ChartCard
      title="Popular `bootc` Operating System Images"
      canvasId="fedora-version-chart"
      height={300}
    />
    <div class="fedora-scale-controls">
      <div class="btn-group" id="fedora-scale-btns" role="group" aria-label="Scale type">
        <button class="range-btn active" data-scale="linear">Linear</button>
        <button class="range-btn" data-scale="log">Log</button>
      </div>
    </div>
    <script type="application/json" id="fedora-version-data" set:html={safeJson({ osVersionDist, DISTRO_ORDER, allVersions, FEDORA_VERSION_PALETTE })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { getChartColors } from '../lib/chart-theme.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('fedora-version-data');
if (dataEl) {
  const { osVersionDist, DISTRO_ORDER, allVersions, FEDORA_VERSION_PALETTE } =
    JSON.parse(dataEl.textContent!);

  const canvas = document.getElementById('fedora-version-chart') as HTMLCanvasElement;
  let currentScale: 'linear' | 'log' = 'linear';

  function buildChart() {
    const c = getChartColors();
    const labels = (DISTRO_ORDER as string[]).filter((d: string) => d in osVersionDist);

    const datasets = (allVersions as string[]).map((ver: string, i: number) => ({
      label: `F${ver}`,
      data: labels.map((distro: string) => (osVersionDist[distro] ?? {})[ver] ?? 0),
      backgroundColor: FEDORA_VERSION_PALETTE[i % FEDORA_VERSION_PALETTE.length],
      borderRadius: 3,
    }));

    const yAxis = currentScale === 'log'
      ? {
          type: 'logarithmic' as const,
          min: 1,
          grid: { color: c.grid },
          ticks: {
            color: c.muted,
            callback: (v: number | string) => {
              const n = Number(v);
              return n >= 1000 ? `${(n / 1000).toFixed(0)}k` : String(n);
            },
          },
        }
      : {
          type: 'linear' as const,
          beginAtZero: true,
          grid: { color: c.grid },
          ticks: {
            color: c.muted,
            callback: (v: number | string) =>
              Number(v) >= 1000 ? `${(Number(v) / 1000).toFixed(0)}k` : String(v),
          },
        };

    if (chart) {
      chart.data.labels = labels;
      chart.data.datasets = datasets;
      chart.options.scales!.x!.ticks!.color = c.muted;
      (chart.options.scales!.x!.grid as { color: string }).color = c.grid;
      // Update y-axis type and options in place
      chart.options.scales!.y = yAxis as typeof chart.options.scales.y;
      (chart.options.plugins!.legend!.labels as { color: string }).color = c.muted;
      chart.update();
      return;
    }

    try {
      chart = new Chart(canvas, {
        type: 'bar',
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: c.muted, usePointStyle: true, boxWidth: 10 } },
          },
          scales: {
            x: {
              grid: { color: c.grid },
              ticks: { color: c.muted },
            },
            y: yAxis,
          },
        },
      });
    } catch (e) {
      console.error('[FedoraVersionChart] Chart.js init failed:', e);
    }
  }

  let chart: Chart | undefined;
  buildChart();

  // Scale toggle
  document.querySelectorAll('#fedora-scale-btns .range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#fedora-scale-btns .range-btn').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      currentScale = (btn as HTMLElement).dataset.scale as 'linear' | 'log';
      buildChart();
    });
  });

  window.addEventListener('themechange', buildChart);
}
</script>

<style>
  .fedora-scale-controls {
    display: flex;
    gap: 8px;
    padding: 6px 12px 0;
    flex-wrap: wrap;
  }
  .btn-group {
    display: flex;
    gap: 4px;
  }
  .range-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 4px;
    padding: 2px 10px;
    font-size: 12px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }
  .range-btn:hover { color: var(--text); background: var(--bg2); }
  .range-btn.active { color: var(--text); background: var(--bg2); border-color: var(--blue); font-weight: 600; }
</style>

