---
interface TapSnapshot {
  uniques: number;
  count: number;
  downloads?: Record<string, number>;
}

interface DaySnapshot {
  date: string;
  taps: Record<string, TapSnapshot>;
}

interface Props {
  tapName: string;
  history: DaySnapshot[];
}

const { tapName, history } = Astro.props;

// Only keep snapshots that have download data for this tap.
const relevant = history.filter(d => d.taps[tapName]?.downloads);

const COLOURS = [
  '#388bfd', '#a371f7', '#3fb950', '#d29922', '#f78166',
  '#79c0ff', '#d2a8ff', '#56d364', '#e3b341', '#ff7b72',
];
const TOP_N = 10;
const safeId = tapName.replace(/\//g, '-');
---

{relevant.length < 2 ? (
  <p class="chart-empty">Not enough history yet — charts will appear after a few daily syncs.</p>
) : (
  <>
    <div class="charts-row">
      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-title">Cumulative Installs Over Time</div>
          <div class="range-btns" id={`range-btns-${safeId}`}>
            <button class="range-btn active" data-range="30">30d</button>
            <button class="range-btn" data-range="90">90d</button>
            <button class="range-btn" data-range="all">All</button>
          </div>
        </div>
        <div class="chart-wrap">
          <canvas id={`total-chart-${safeId}`}></canvas>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Top {TOP_N} Packages Over Time</div>
        <div class="chart-wrap">
          <canvas id={`pkg-chart-${safeId}`}></canvas>
        </div>
      </div>
    </div>
    <script type="application/json" id={`downloads-data-${safeId}`}>{JSON.stringify({ tapName, relevant, COLOURS, TOP_N })}</script>
  </>
)}

<script>
  import Chart from 'chart.js/auto';

  function getCSSVar(name) {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }
  function getChartColors() {
    return {
      text: getCSSVar('--text'),
      muted: getCSSVar('--muted'),
      grid: getCSSVar('--border'),
    };
  }

  // Collect all chart instances so the theme-change listener can update them all.
  const allCharts = [];

  // Each DownloadsChart instance emits a JSON data tag; scan them all so this
  // single deduplicated module script initialises every chart on the page.
  document.querySelectorAll('[id^="downloads-data-"]').forEach(el => {
    const { tapName, relevant: allRelevant, COLOURS, TOP_N } = JSON.parse(el.textContent);
    const safeId = tapName.replace(/\//g, '-');

    // Determine top N packages by most recent snapshot's download counts.
    // Always based on the FULL dataset so the same packages appear across all ranges.
    const latest = allRelevant[allRelevant.length - 1].taps[tapName]?.downloads ?? {};
    const ranked = Object.entries(latest)
      .sort((a, b) => b[1] - a[1])
      .map(([name]) => name);
    const topPkgs = ranked.slice(0, TOP_N);
    const restPkgs = ranked.slice(TOP_N);

    const sharedScales = () => {
      const c = getChartColors();
      return {
        x: {
          ticks: { color: c.muted, font: { size: 11 }, maxRotation: 45 },
          grid: { color: c.grid },
        },
        y: {
          beginAtZero: true,
          ticks: { color: c.muted, font: { size: 11 }, callback: v => Number(v).toLocaleString() },
          grid: { color: c.grid },
        },
      };
    };

    // ── Cumulative installs helper ────────────────────────────────────────
    // Each history snapshot holds 30-day rolling window totals from the
    // Homebrew analytics API — not daily deltas.  To build a true running
    // total we:
    //   • Use day-0's 30d total as the starting baseline.
    //   • For every subsequent day, add only the positive delta
    //     (today's 30d total minus yesterday's 30d total, clamped ≥ 0).
    //     Negative deltas (old installs aging out of the window) are
    //     ignored — we never subtract from the cumulative count.
    function computeCumulative(data) {
      let running = 0;
      return data.map((d, i) => {
        const curr = d.taps[tapName]?.downloads ?? {};
        const currTotal = Object.values(curr).reduce((s, n) => s + n, 0);
        if (i === 0) {
          running = currTotal;
        } else {
          const prev = data[i - 1].taps[tapName]?.downloads ?? {};
          const prevTotal = Object.values(prev).reduce((s, n) => s + n, 0);
          running += Math.max(0, currTotal - prevTotal);
        }
        return running;
      });
    }

    function buildPkgDatasets(data) {
      const sets = topPkgs.map((name, i) => ({
        label: name,
        data: data.map(d => d.taps[tapName]?.downloads?.[name] ?? null),
        borderColor: COLOURS[i % COLOURS.length],
        backgroundColor: 'transparent',
        tension: 0.3,
        pointRadius: data.length < 15 ? 3 : 1,
        spanGaps: true,
      }));

      if (restPkgs.length > 0) {
        sets.push({
          label: `other (${restPkgs.length} packages)`,
          data: data.map(d => {
            const pkgs = d.taps[tapName]?.downloads ?? {};
            return restPkgs.reduce((s, name) => s + (pkgs[name] ?? 0), 0);
          }),
          borderColor: '#7d8590',
          backgroundColor: 'transparent',
          borderDash: [4, 4],
          tension: 0.3,
          pointRadius: 0,
          spanGaps: true,
        });
      }
      return sets;
    }

    function getWindow(range) {
      if (range === '30') return allRelevant.slice(-30);
      if (range === '90') return allRelevant.slice(-90);
      return allRelevant;
    }

    let relevant = getWindow('30');
    const colors = getChartColors();

    // ── Chart A: Cumulative installs over time ─────────────────────────
    // ── Chart B: Top N packages + "other" aggregate ───────────────────
    let chartA, chartB;
    try {
      chartA = new Chart(document.getElementById(`total-chart-${safeId}`), {
        type: 'line',
        data: {
          labels: relevant.map(d => d.date),
          datasets: [{
            label: 'Cumulative installs',
            data: computeCumulative(relevant),
            borderColor: COLOURS[0],
            backgroundColor: COLOURS[0] + '22',
            fill: true,
            tension: 0.3,
            pointRadius: relevant.length < 15 ? 4 : 2,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => `${ctx.parsed.y?.toLocaleString() ?? '—'} cumulative installs`,
              },
            },
          },
          scales: sharedScales(),
        },
      });

      chartB = new Chart(document.getElementById(`pkg-chart-${safeId}`), {
        type: 'line',
        data: {
          labels: relevant.map(d => d.date),
          datasets: buildPkgDatasets(relevant),
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              labels: { color: colors.text, font: { size: 11 }, boxWidth: 12 },
            },
            tooltip: {
              callbacks: {
                label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'}`,
              },
            },
          },
          scales: sharedScales(),
        },
      });
    } catch (e) {
      console.error('[DownloadsChart] Chart.js init failed:', e);
    }

    // ── Time range selector ───────────────────────────────────────────
    document.querySelectorAll(`#range-btns-${safeId} .range-btn`).forEach(btn => {
      btn.addEventListener('click', () => {
        if (!chartA || !chartB) return;
        document.querySelectorAll(`#range-btns-${safeId} .range-btn`).forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const data = getWindow(btn.dataset.range);

        chartA.data.labels = data.map(d => d.date);
        chartA.data.datasets[0].data = computeCumulative(data);
        chartA.data.datasets[0].pointRadius = data.length < 15 ? 4 : 2;
        chartA.update();

        chartB.data.labels = data.map(d => d.date);
        chartB.data.datasets = buildPkgDatasets(data);
        chartB.update();
      });
    });

    if (chartA && chartB) allCharts.push({ chartA, chartB, sharedScales, getColors: getChartColors });
  });

  window.addEventListener('themechange', () => {
    allCharts.forEach(({ chartA, chartB, sharedScales, getColors }) => {
      const c = getColors();
      const scales = sharedScales();

      chartA.options.scales.x.ticks.color = scales.x.ticks.color;
      chartA.options.scales.x.grid.color = scales.x.grid.color;
      chartA.options.scales.y.ticks.color = scales.y.ticks.color;
      chartA.options.scales.y.grid.color = scales.y.grid.color;
      chartA.update();

      chartB.options.plugins.legend.labels.color = c.text;
      chartB.options.scales.x.ticks.color = scales.x.ticks.color;
      chartB.options.scales.x.grid.color = scales.x.grid.color;
      chartB.options.scales.y.ticks.color = scales.y.ticks.color;
      chartB.options.scales.y.grid.color = scales.y.grid.color;
      chartB.update();
    });
  });
</script>

<style>
  .chart-empty {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 16px;
  }

  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .charts-row { grid-template-columns: 1fr; }
  }

  .chart-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
  }

  .chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .chart-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Standalone title (not inside chart-header) needs its own bottom gap */
  .chart-card > .chart-title {
    margin-bottom: 12px;
  }

  .chart-wrap {
    position: relative;
    height: 240px;
  }

  .range-btns {
    display: flex;
    gap: 4px;
  }

  .range-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 11px;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .range-btn:hover {
    background: var(--bg);
    color: var(--text);
  }

  .range-btn.active {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
</style>
