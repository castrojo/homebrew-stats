---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface Props {
  tapName: string;
  history: { date: string; taps: Record<string, { uniques: number; count: number; downloads?: Record<string, number> }> }[];
}

const { tapName, history } = Astro.props;

const relevant = history.filter(d => d.taps[tapName]?.downloads);

const TOP_N = 10;
const safeId = tapName.replace(/\//g, '-');
---

{relevant.length < 2 ? (
  <p class="chart-empty">Not enough history yet — charts will appear after a few daily syncs.</p>
) : (
  <>
    <div class="charts-row">
      <ChartCard
        title="Cumulative Installs Over Time"
        canvasId={`total-chart-${safeId}`}
        height={240}
        rangeId={`range-btns-${safeId}`}
        ranges={[{ label: '30d', value: '30' }, { label: '90d', value: '90' }, { label: '365d', value: '365' }, { label: 'All', value: 'all' }]}
        defaultRange="30"
      />
      <ChartCard
        title={`Top ${TOP_N} Packages Over Time`}
        canvasId={`pkg-chart-${safeId}`}
        height={240}
      />
    </div>
    <script type="application/json" id={`downloads-data-${safeId}`} set:html={safeJson({ tapName, relevant, TOP_N })}></script>
  </>
)}

<script>
  import '../lib/chart-registry.js';
  import { BRAND_COLOURS, getChartColors } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  type DaySnap = { date: string; taps: Record<string, { downloads?: Record<string, number> }> };


  // Collect all chart instances so the theme-change listener can update them all.
  const allCharts: Array<{
    chartA: Chart;
    chartB: Chart;
    getScales: () => ReturnType<typeof sharedScales>;
  }> = [];

  function sharedScales() {
    const c = getChartColors();
    return {
      x: {
        ticks: { color: c.muted, font: { size: 11 }, maxRotation: 45 },
        grid: { color: c.grid },
      },
      y: {
        beginAtZero: true,
        ticks: { color: c.muted, font: { size: 11 }, callback: (v: number | string) => Number(v).toLocaleString() },
        grid: { color: c.grid },
      },
    };
  }

  // Each DownloadsChart instance emits a JSON data tag; scan them all so this
  // single deduplicated module script initialises every chart on the page.
  document.querySelectorAll('[id^="downloads-data-"]').forEach(el => {
    const { tapName, relevant: allRelevant, TOP_N } = JSON.parse((el as HTMLElement).textContent!);
    const safeId = tapName.replace(/\//g, '-');

    // Determine top N packages by most recent snapshot's download counts.
    const latest = allRelevant[allRelevant.length - 1].taps[tapName]?.downloads ?? {};
    const ranked = Object.entries(latest as Record<string, number>)
      .sort((a, b) => b[1] - a[1])
      .map(([name]) => name);
    const topPkgs = ranked.slice(0, TOP_N);
    const restPkgs = ranked.slice(TOP_N);

    // ── Cumulative installs helper ────────────────────────────────────────
    function computeCumulative(data: DaySnap[]) {
      let running = 0;
      return data.map((d, i) => {
        const curr = d.taps[tapName]?.downloads ?? {};
        const currTotal = Object.values(curr as Record<string, number>).reduce((s, n) => s + n, 0);
        if (i === 0) {
          running = currTotal;
        } else {
          const prev = data[i - 1].taps[tapName]?.downloads ?? {};
          const prevTotal = Object.values(prev as Record<string, number>).reduce((s, n) => s + n, 0);
          running += Math.max(0, currTotal - prevTotal);
        }
        return running;
      });
    }

    function buildPkgDatasets(data: DaySnap[]) {
      const sets = topPkgs.map((name: string, i: number) => ({
        label: name,
        data: data.map(d => (d.taps[tapName]?.downloads as Record<string, number> | undefined)?.[name] ?? null),
        borderColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
        backgroundColor: 'transparent',
        tension: 0.3,
        pointRadius: data.length < 15 ? 3 : 1,
        spanGaps: true,
      }));

      if (restPkgs.length > 0) {
        sets.push({
          label: `other (${restPkgs.length} packages)`,
          data: data.map(d => {
            const pkgs = d.taps[tapName]?.downloads as Record<string, number> | undefined ?? {};
            return restPkgs.reduce((s: number, name: string) => s + (pkgs[name] ?? 0), 0);
          }),
          borderColor: '#7d8590',
          backgroundColor: 'transparent',
          borderDash: [4, 4],
          tension: 0.3,
          pointRadius: 0,
          spanGaps: true,
        });
      }
      return sets;
    }

    function getWindow(range: string) {
      if (range === '30') return allRelevant.slice(-30);
      if (range === '90') return allRelevant.slice(-90);
      if (range === '365') return allRelevant.slice(-365);
      return allRelevant;
    }

    let relevant = getWindow('30');
    const colors = getChartColors();

    let chartA: Chart | undefined, chartB: Chart | undefined;
    try {
      chartA = new Chart(document.getElementById(`total-chart-${safeId}`) as HTMLCanvasElement, {
        type: 'line',
        data: {
          labels: relevant.map((d: DaySnap) => d.date),
          datasets: [{
            label: 'Cumulative installs',
            data: computeCumulative(relevant),
            borderColor: BRAND_COLOURS[0],
            backgroundColor: BRAND_COLOURS[0] + '22',
            fill: true,
            tension: 0.3,
            pointRadius: relevant.length < 15 ? 4 : 2,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => `${ctx.parsed.y?.toLocaleString() ?? '—'} cumulative installs`,
              },
            },
          },
          scales: sharedScales(),
        },
      });

      chartB = new Chart(document.getElementById(`pkg-chart-${safeId}`) as HTMLCanvasElement, {
        type: 'line',
        data: {
          labels: relevant.map((d: DaySnap) => d.date),
          datasets: buildPkgDatasets(relevant),
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              labels: { color: colors.text, font: { size: 11 }, boxWidth: 12 },
            },
            tooltip: {
              callbacks: {
                label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? '—'}`,
              },
            },
          },
          scales: sharedScales(),
        },
      });
    } catch (e) {
      console.error('[DownloadsChart] Chart.js init failed:', e);
    }

    // ── Time range selector ───────────────────────────────────────────
    document.querySelectorAll(`#range-btns-${safeId} .range-btn`).forEach(btn => {
      btn.addEventListener('click', () => {
        if (!chartA || !chartB) return;
        document.querySelectorAll(`#range-btns-${safeId} .range-btn`).forEach(b => b.classList.remove('active'));
        (btn as HTMLElement).classList.add('active');
        const data = getWindow((btn as HTMLElement).dataset.range!);

        chartA.data.labels = data.map((d: DaySnap) => d.date);
        chartA.data.datasets[0].data = computeCumulative(data);
        (chartA.data.datasets[0] as { pointRadius: number }).pointRadius = data.length < 15 ? 4 : 2;
        chartA.update();

        chartB.data.labels = data.map((d: DaySnap) => d.date);
        chartB.data.datasets = buildPkgDatasets(data);
        chartB.update();
      });
    });

    if (chartA && chartB) {
      allCharts.push({ chartA, chartB, getScales: sharedScales });
    }
  });

  window.addEventListener('themechange', () => {
    allCharts.forEach(({ chartA, chartB, getScales }) => {
      const scales = getScales();
      const c = getChartColors();

      chartA.options.scales!.x!.ticks!.color = scales.x.ticks.color;
      (chartA.options.scales!.x!.grid as { color: string }).color = scales.x.grid.color;
      chartA.options.scales!.y!.ticks!.color = scales.y.ticks.color;
      (chartA.options.scales!.y!.grid as { color: string }).color = scales.y.grid.color;
      chartA.update();

      (chartB.options.plugins!.legend!.labels as { color: string }).color = c.text;
      chartB.options.scales!.x!.ticks!.color = scales.x.ticks.color;
      (chartB.options.scales!.x!.grid as { color: string }).color = scales.x.grid.color;
      chartB.options.scales!.y!.ticks!.color = scales.y.ticks.color;
      (chartB.options.scales!.y!.grid as { color: string }).color = scales.y.grid.color;
      chartB.update();
    });
  });
</script>

<style>
  .chart-empty {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 16px;
  }

  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .charts-row { grid-template-columns: 1fr; }
  }
</style>
