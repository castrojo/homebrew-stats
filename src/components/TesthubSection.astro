---
interface TesthubPackage {
  name: string;
  version?: string;
  html_url?: string;
}

interface Props {
  testhub: {
    org: string;
    url: string;
    packages: TesthubPackage[];
  };
}

const { testhub } = Astro.props;
---

<div class="testhub-section">
  <div class="tap-header">
    <h2><a href={testhub.url}>🧪 projectbluefin/testhub (Flatpak OCI)</a></h2>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value">{testhub.packages.length}</div>
      <div class="stat-label">Flatpak Packages</div>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Package</th>
        <th>Version</th>
      </tr>
    </thead>
    <tbody>
      {testhub.packages.map((pkg) => (
        <tr>
          <td>
            {pkg.html_url
              ? <a href={pkg.html_url}>{pkg.name}</a>
              : pkg.name}
          </td>
          <td class="mono">{pkg.version || '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p class="testhub-note">
    Packages distributed as Flatpak OCI blobs via <a href="https://ghcr.io">GHCR</a>.
    Source: <a href="https://github.com/projectbluefin/testhub">projectbluefin/testhub</a>.
  </p>
</div>

<style>
  .testhub-section { margin-bottom: 48px; }

  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
    min-width: 120px;
    flex: 1;
  }

  .stat-value {
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    font-size: 13px;
  }

  th, td {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  th {
    background: var(--bg);
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(48, 54, 61, 0.5); }

  td a { color: var(--text); font-weight: 500; }
  td a:hover { color: var(--link); }

  .mono { font-family: 'SF Mono', Consolas, monospace; font-size: 12px; color: var(--muted); }
  .testhub-note { font-size: 11px; color: var(--muted); margin-top: 12px; }
</style>
