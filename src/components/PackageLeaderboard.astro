---
interface Package {
  name: string;
  downloads?: number;
  installs_90d?: number;
  installs_365d?: number;
}

interface Tap {
  name: string;
  packages: Package[];
}

interface Props {
  taps: Tap[];
}

interface Row {
  package: string;
  tapName: string;
  installs30d: number;
  installs90d: number;
  installs365d: number;
}

const { taps } = Astro.props;

const BADGE_LABELS: Record<string, string> = {
  'ublue-os/homebrew-tap': 'ublue-os/tap',
  'ublue-os/homebrew-experimental-tap': 'ublue-os/experimental',
  'bluefin/brewfile': 'homebrew',
  'bazzite/brewfile': 'homebrew',
};

function tapBadgeLabel(tapName: string): string {
  return BADGE_LABELS[tapName] ?? tapName.replace('homebrew-', '');
}

function tapBadgeCssClass(label: string): string {
  return label.replace(/\//g, '-').replace(/homebrew-/g, '');
}

const seen = new Set<string>();
const rows: Row[] = taps.flatMap(tap =>
  tap.packages.map(pkg => ({
    package: pkg.name,
    tapName: tapBadgeLabel(tap.name),
    installs30d: pkg.downloads ?? 0,
    installs90d: pkg.installs_90d ?? 0,
    installs365d: pkg.installs_365d ?? 0,
  }))
).filter(row => {
  const key = `${row.tapName}::${row.package}`;
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

rows.sort((a, b) => b.installs30d - a.installs30d);
---

<section class="leaderboard-section">
  <div class="leaderboard-toolbar">
    <input id="pkg-search" type="search" placeholder="Filter package or tap…" autocomplete="off" />
  </div>
  <div class="leaderboard-wrap">
    <table id="pkg-leaderboard">
      <thead>
        <tr>
          <th data-col="package" class="sortable">Package <span class="sort-icon"></span></th>
          <th data-col="tap" class="sortable">Tap <span class="sort-icon"></span></th>
          <th data-col="installs30d" class="sortable sort-active sort-desc">30d installs <span class="sort-icon">↓</span></th>
          <th data-col="installs90d" class="sortable">90d installs <span class="sort-icon"></span></th>
          <th data-col="installs365d" class="sortable">365d installs <span class="sort-icon"></span></th>
        </tr>
      </thead>
      <tbody>
        {rows.map(row => (
          <tr
            data-package={row.package}
            data-tap={row.tapName}
            data-installs30d={row.installs30d}
            data-installs90d={row.installs90d}
            data-installs365d={row.installs365d}
          >
            <td class="pkg-cell">
              <span class="pkg-name">{row.package}</span>
            </td>
            <td>
              <span class={`tap-badge tap-${tapBadgeCssClass(row.tapName)}`}>{row.tapName}</span>
            </td>
            <td class="num-cell">{row.installs30d > 0 ? row.installs30d.toLocaleString() : '—'}</td>
            <td class="num-cell">{row.installs90d > 0 ? row.installs90d.toLocaleString() : '—'}</td>
            <td class="num-cell">{row.installs365d > 0 ? row.installs365d.toLocaleString() : '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<script>
  const table = document.getElementById('pkg-leaderboard') as HTMLTableElement | null;
  const searchInput = document.getElementById('pkg-search') as HTMLInputElement | null;

  if (table) {
    const headers = Array.from(table.querySelectorAll<HTMLTableCellElement>('th[data-col]'));
    let currentCol = 'installs30d';
    let currentDir: 'asc' | 'desc' = 'desc';

    function getValue(row: HTMLTableRowElement, col: string): string | number {
      switch (col) {
        case 'installs30d': return parseInt(row.dataset.installs30d ?? '0', 10);
        case 'installs90d': return parseInt(row.dataset.installs90d ?? '0', 10);
        case 'installs365d': return parseInt(row.dataset.installs365d ?? '0', 10);
        case 'package': return (row.dataset.package ?? '').toLowerCase();
        case 'tap': return (row.dataset.tap ?? '').toLowerCase();
        default: return '';
      }
    }

    function refreshHeaders(activeCol: string, dir: 'asc' | 'desc') {
      headers.forEach(th => {
        const icon = th.querySelector<HTMLElement>('.sort-icon');
        th.classList.remove('sort-active', 'sort-asc', 'sort-desc');
        if (icon) icon.textContent = '';

        if (th.dataset.col === activeCol) {
          th.classList.add('sort-active', dir === 'asc' ? 'sort-asc' : 'sort-desc');
          if (icon) icon.textContent = dir === 'asc' ? '↑' : '↓';
        }
      });
    }

    function sortTable(col: string, dir: 'asc' | 'desc') {
      const tbody = table.querySelector('tbody');
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
      rows.sort((a, b) => {
        const va = getValue(a, col);
        const vb = getValue(b, col);
        if (typeof va === 'number' && typeof vb === 'number') {
          return dir === 'asc' ? va - vb : vb - va;
        }
        return dir === 'asc'
          ? String(va).localeCompare(String(vb))
          : String(vb).localeCompare(String(va));
      });
      rows.forEach(row => tbody.appendChild(row));
    }

    headers.forEach(th => {
      th.style.cursor = 'pointer';
      th.addEventListener('click', () => {
        const col = th.dataset.col!;
        if (col === currentCol) {
          currentDir = currentDir === 'asc' ? 'desc' : 'asc';
        } else {
          currentCol = col;
          currentDir = col.startsWith('installs') ? 'desc' : 'asc';
        }
        sortTable(currentCol, currentDir);
        refreshHeaders(currentCol, currentDir);
      });
    });
  }

  if (searchInput && table) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      table.querySelectorAll<HTMLTableRowElement>('tbody tr').forEach(row => {
        const name = (row.dataset.package ?? '').toLowerCase();
        const tap = (row.dataset.tap ?? '').toLowerCase();
        row.style.display = (!q || name.includes(q) || tap.includes(q)) ? '' : 'none';
      });
    });
  }
</script>

<style>
  .leaderboard-section {
    margin-bottom: 32px;
  }

  .leaderboard-toolbar {
    margin-bottom: 12px;
  }

  #pkg-search {
    width: 280px;
    max-width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 7px 12px;
    font-size: 13px;
  }

  #pkg-search:focus {
    outline: none;
    border-color: var(--accent);
  }

  #pkg-search::placeholder {
    color: var(--muted);
  }

  .leaderboard-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  th, td {
    padding: 11px 14px;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr:hover td {
    background: var(--bg3);
  }

  th {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 11px;
    color: var(--muted);
    background: var(--bg);
    white-space: nowrap;
    user-select: none;
  }

  th.sort-active {
    color: var(--purple);
  }

  .sort-icon {
    width: 12px;
    display: inline-block;
  }

  .pkg-name {
    font-weight: 600;
    color: var(--text);
  }

  .num-cell {
    font-variant-numeric: tabular-nums;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .tap-badge {
    display: inline-block;
    border-radius: 999px;
    padding: 2px 9px;
    font-size: 11px;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .tap-stable {
    background: rgba(120, 41, 139, 0.2);
    border-color: rgba(175, 104, 217, 0.45);
    color: #d8b4f1;
  }

  .tap-experimental {
    background: rgba(146, 50, 169, 0.16);
    border-color: rgba(146, 50, 169, 0.45);
    color: #e2c6f1;
  }

  .tap-ublue-os-tap {
    background: rgba(120, 41, 139, 0.2);
    border-color: rgba(175, 104, 217, 0.45);
    color: #d8b4f1;
  }

  .tap-ublue-os-experimental {
    background: rgba(146, 50, 169, 0.16);
    border-color: rgba(146, 50, 169, 0.45);
    color: #e2c6f1;
  }

  .tap-homebrew {
    background: rgba(251, 146, 60, 0.15);
    border-color: rgba(251, 146, 60, 0.45);
    color: #fdba74;
  }
</style>
