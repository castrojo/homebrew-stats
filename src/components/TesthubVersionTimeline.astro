---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface DaySnapshot {
  date: string;
  packages: { version_count: number }[] | null;
}

interface Props { history: DaySnapshot[]; }
const { history } = Astro.props;

let previousTotal = 0;
const timeline = [...history]
  .sort((a, b) => a.date.localeCompare(b.date))
  .map((snapshot) => {
    if (snapshot.packages && snapshot.packages.length > 0) {
      previousTotal = snapshot.packages.reduce((sum, pkg) => sum + (pkg.version_count ?? 0), 0);
    }
    return {
      date: snapshot.date,
      totalVersions: previousTotal,
    };
  });
---

{timeline.length === 0 ? (
  <ChartCard title="Published Versions Over Time" canvasId="testhub-version-chart" isEmpty emptyMsg="Collecting data…" />
) : (
  <>
    <ChartCard
      title="Published Versions Over Time"
      canvasId="testhub-version-chart"
      height={300}
    />
    <script type="application/json" id="testhub-version-data" set:html={safeJson({ timeline, history: timeline })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { getChartColors } from '../lib/chart-theme.js';
import { readChartData } from '../lib/inject.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('testhub-version-data');
if (dataEl) {
  const { timeline } = readChartData<{
    timeline: { date: string; totalVersions: number }[]
  }>('testhub-version-data');
  const canvas = document.getElementById('testhub-version-chart') as HTMLCanvasElement;

  function makeGradient(chart: Chart, topColor: string, bottomColor: string): CanvasGradient | string {
    const { ctx, chartArea } = chart;
    if (!chartArea) return topColor;
    const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
    gradient.addColorStop(0, topColor);
    gradient.addColorStop(1, bottomColor);
    return gradient;
  }

  const c = getChartColors();

  let chart: Chart | undefined;
  try {
    chart = new Chart(canvas, {
      type: 'line',
      data: {
        labels: timeline.map((point) => point.date),
        datasets: [
          {
            label: 'Total versions',
            data: timeline.map((point) => point.totalVersions),
            borderColor: '#af68d9',
            backgroundColor: (ctx) => makeGradient(ctx.chart, 'rgba(175,104,217,0.45)', 'rgba(175,104,217,0.03)'),
            fill: true,
            tension: 0.35,
            pointRadius: 2,
            pointHoverRadius: 4,
            pointBackgroundColor: '#af68d9',
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            type: 'category',
            grid: { color: c.grid },
            ticks: { color: c.muted, maxTicksLimit: 10 },
          },
          y: {
            beginAtZero: true,
            grid: { color: c.grid },
            ticks: { color: c.muted },
          },
        },
        plugins: {
          legend: { display: false },
        },
      },
    });
  } catch (e) {
    console.error('[TesthubVersionTimeline] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const colors = getChartColors();
    chart.options.scales!.x!.ticks!.color = colors.muted;
    (chart.options.scales!.x!.grid as { color: string }).color = colors.grid;
    chart.options.scales!.y!.ticks!.color = colors.muted;
    (chart.options.scales!.y!.grid as { color: string }).color = colors.grid;
    chart.update('none');
  });
}
</script>
