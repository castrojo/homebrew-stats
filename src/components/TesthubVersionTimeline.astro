---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';
import type { Package } from '../lib/types.ts';

interface DaySnapshot {
  date: string;
  packages: Package[];
  build_counts: { app: string }[];
  last_run_id: number;
}

interface Props { history: DaySnapshot[]; }
const { history } = Astro.props;
---

{history.length === 0 ? (
  <ChartCard title="Version Change Timeline" canvasId="testhub-version-chart" isEmpty emptyMsg="Collecting data…" />
) : (
  <>
    <ChartCard
      title="Version Change Timeline"
      canvasId="testhub-version-chart"
      height={300}
    />
    <script type="application/json" id="testhub-version-data" set:html={safeJson({ history })}></script>
  </>
)}

<script>
import '../lib/chart-registry.js';
import { BRAND_COLOURS, getChartColors } from '../lib/chart-theme.js';
import { readChartData } from '../lib/inject.js';
import { Chart } from 'chart.js';

const dataEl = document.getElementById('testhub-version-data');
if (dataEl) {
  const { history } = readChartData<{
    history: { date: string; packages: { name: string; version?: string }[]; build_counts: { app: string }[]; last_run_id: number }[]
  }>('testhub-version-data');
  const canvas = document.getElementById('testhub-version-chart') as HTMLCanvasElement;

  const appSet = new Set<string>();
  for (const snap of history) {
    for (const pkg of snap.packages) appSet.add(pkg.name);
  }
  const apps = Array.from(appSet).sort();

  interface VersionChange { date: string; version: string; app: string }
  const changes: VersionChange[] = [];
  for (const app of apps) {
    let prevVer: string | undefined;
    for (const snap of history) {
      const pkg = snap.packages.find((p: { name: string }) => p.name === app);
      if (!pkg) continue;
      const ver = pkg.version ?? '';
      if (prevVer !== undefined && ver !== prevVer) {
        changes.push({ date: snap.date, version: ver, app });
      }
      prevVer = ver;
    }
  }

  const c = getChartColors();

  const datasets = apps.map((app: string, i: number) => {
    const pts = changes
      .filter((ch: VersionChange) => ch.app === app)
      .map((ch: VersionChange) => ({ x: ch.date, y: i, label: ch.version }));
    return {
      label: app,
      data: pts,
      backgroundColor: BRAND_COLOURS[i % BRAND_COLOURS.length],
      pointRadius: 8,
      pointHoverRadius: 10,
    };
  }).filter((ds: { data: unknown[] }) => ds.data.length > 0);

  let chart: Chart | undefined;
  try {
    chart = new Chart(canvas, {
      type: 'scatter',
      data: { datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            type: 'category',
            labels: history.map((s: { date: string }) => s.date),
            grid: { color: c.grid },
            ticks: { color: c.muted, maxTicksLimit: 10 },
          },
          y: {
            type: 'category',
            labels: apps,
            grid: { color: c.grid },
            ticks: { color: c.muted },
            offset: true,
          },
        },
        plugins: {
          legend: { labels: { color: c.text, usePointStyle: true, boxWidth: 8 } },
          tooltip: {
            callbacks: {
              label: (ctx: { raw: { label?: string; x: string } }) =>
                `${ctx.raw.label ?? ''} (${ctx.raw.x})`,
            },
          },
        },
      },
    });
  } catch (e) {
    console.error('[TesthubVersionTimeline] Chart.js init failed:', e);
  }

  window.addEventListener('themechange', () => {
    if (!chart) return;
    const colors = getChartColors();
    (chart.options.plugins!.legend!.labels as { color: string }).color = colors.text;
    chart.options.scales!.x!.ticks!.color = colors.muted;
    (chart.options.scales!.x!.grid as { color: string }).color = colors.grid;
    chart.options.scales!.y!.ticks!.color = colors.muted;
    (chart.options.scales!.y!.grid as { color: string }).color = colors.grid;
    chart.update();
  });
}
</script>
