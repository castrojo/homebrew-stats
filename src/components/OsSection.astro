---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface OSEntry {
  os: string;
  count: number;
  percent: number;
}

interface PeriodData {
  period: string;
  items: OSEntry[];
}

interface Props {
  osAnalytics: { periods: PeriodData[] };
}

const { osAnalytics } = Astro.props;

const period30  = osAnalytics.periods.find(p => p.period === '30d');
const period90  = osAnalytics.periods.find(p => p.period === '90d');
const period365 = osAnalytics.periods.find(p => p.period === '365d');
---

<ChartCard
  title="Linux OS Distribution"
  canvasId="os-bar-chart"
  height={320}
  rangeId="os-period-btns"
  ranges={[{ label: '30d', value: '30d' }, { label: '90d', value: '90d' }, { label: '365d', value: '365d' }]}
  defaultRange="30d"
/>
<script type="application/json" id="os-data" set:html={safeJson({ periods: {
  '30d':  period30  ? period30.items.slice(0, 10)  : [],
  '90d':  period90  ? period90.items.slice(0, 10)  : [],
  '365d': period365 ? period365.items.slice(0, 10) : [],
} })}></script>

<script>
import '../lib/chart-registry.js';
import { readChartData } from '../lib/inject.js';
import { BRAND_COLOURS, getChartColors } from '../lib/chart-theme.js';
import { Chart } from 'chart.js';

const { periods } = readChartData<{
  periods: Record<string, { os: string; percent: number }[]>;
}>('os-data');

function buildData(items: { os: string; percent: number }[]) {
  return {
    labels: items.map(i => i.os),
    datasets: [{
      label: '% of installs',
      data: items.map(i => i.percent),
      backgroundColor: BRAND_COLOURS[0] + '99',
      borderColor: BRAND_COLOURS[0],
      borderWidth: 1,
      borderRadius: 3,
    }],
  };
}

let currentPeriod = '30d';
const colors = getChartColors();

let chart: Chart | undefined;
try {
  chart = new Chart(document.getElementById('os-bar-chart') as HTMLCanvasElement, {
    type: 'bar',
    data: buildData(periods[currentPeriod]),
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (ctx) => ` ${ctx.parsed.x.toFixed(2)}%`,
          },
        },
      },
      scales: {
        x: {
          beginAtZero: true,
          grid: { color: colors.grid },
          ticks: {
            color: colors.muted,
            font: { size: 11 },
            callback: (v) => `${v}%`,
          },
        },
        y: {
          grid: { display: false },
          ticks: {
            color: colors.text,
            font: { size: 12 },
          },
        },
      },
    },
  });
} catch (e) {
  console.error('[OsSection] Chart.js init failed:', e);
}

document.querySelectorAll('#os-period-btns .range-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    if (!chart) return;
    document.querySelectorAll('#os-period-btns .range-btn').forEach(b => b.classList.remove('active'));
    (btn as HTMLElement).classList.add('active');
    const period = (btn as HTMLElement).dataset.range!;
    chart.data = buildData(periods[period]);
    chart.update();
  });
});

window.addEventListener('themechange', () => {
  if (!chart) return;
  const c = getChartColors();
  (chart.data.datasets[0] as { backgroundColor: string; borderColor: string }).backgroundColor = BRAND_COLOURS[0] + '99';
  (chart.data.datasets[0] as { backgroundColor: string; borderColor: string }).borderColor = BRAND_COLOURS[0];
  chart.options.scales!.x!.grid!.color = c.grid;
  chart.options.scales!.x!.ticks!.color = c.muted;
  chart.options.scales!.y!.ticks!.color = c.text;
  chart.update();
});
</script>
