---
interface OSEntry {
  os: string;
  count: number;
  percent: number;
}

interface PeriodData {
  period: string;
  items: OSEntry[];
}

interface Props {
  osAnalytics: { periods: PeriodData[] };
}

const { osAnalytics } = Astro.props;

const period30  = osAnalytics.periods.find(p => p.period === '30d');
const period90  = osAnalytics.periods.find(p => p.period === '90d');
const period365 = osAnalytics.periods.find(p => p.period === '365d');

const periods = [
  { label: 'Last 30 Days',  data: period30  },
  { label: 'Last 90 Days',  data: period90  },
  { label: 'Last 365 Days', data: period365 },
];
---

<div class="os-grid">
  {periods.map(({ label, data }) => (
    <div class="os-col">
      <div class="os-col-header">
        <span class="os-window-label">{label}</span>
      </div>
      {data ? (
        <table class="os-table">
          <thead>
            <tr>
              <th class="os-rank">#</th>
              <th>OS</th>
              <th></th>
              <th class="os-count">Count</th>
              <th class="os-pct">%</th>
            </tr>
          </thead>
          <tbody>
            {data.items.map((entry, i) => {
              const max = data.items[0]?.percent ?? 1;
              const barWidth = max > 0 ? Math.round((entry.percent / max) * 100) : 0;
              return (
                <tr>
                  <td class="os-rank">{i + 1}</td>
                  <td class="os-name">{entry.os}</td>
                  <td class="os-bar-cell">
                    <div class="os-bar-track">
                      <div class="os-bar-fill" style={`width:${barWidth}%`}></div>
                    </div>
                  </td>
                  <td class="os-count">{entry.count.toLocaleString()}</td>
                  <td class="os-pct">{entry.percent.toFixed(2)}%</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      ) : (
        <p class="no-data">No data available.</p>
      )}
    </div>
  ))}
</div>

<style>
  .os-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  @media (max-width: 900px) {
    .os-grid { grid-template-columns: 1fr; }
  }

  .os-col-header {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
  }

  .os-window-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }

  .os-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    font-size: 13px;
  }

  .os-table th {
    background: var(--bg);
    padding: 8px 10px;
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .os-table td {
    padding: 7px 10px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    color: var(--text);
  }

  .os-table tr:last-child td { border-bottom: none; }
  .os-table tr:hover td { background: rgba(48, 54, 61, 0.5); }

  .os-rank {
    color: var(--muted);
    font-size: 11px;
    width: 24px;
    text-align: right;
    padding-right: 6px !important;
  }

  .os-name { color: var(--text); }

  .os-count {
    color: var(--muted);
    font-size: 11px;
    white-space: nowrap;
    text-align: right;
  }

  .os-pct {
    color: var(--muted);
    font-size: 11px;
    white-space: nowrap;
    text-align: right;
  }

  .os-bar-cell {
    width: 60px;
    padding: 0 8px !important;
  }

  .os-bar-track {
    background: var(--border);
    border-radius: 2px;
    height: 6px;
    overflow: hidden;
  }

  .os-bar-fill {
    background: var(--blue);
    height: 6px;
    border-radius: 2px;
  }

  .no-data {
    color: var(--muted);
    font-size: 13px;
  }
</style>
