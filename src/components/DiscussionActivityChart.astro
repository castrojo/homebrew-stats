---
import ChartCard from './ChartCard.astro';
import { safeJson } from '../lib/inject.ts';

interface WeekEntry {
  week: string;
  discussions: number;
  comments: number;
}

interface DiscussionSummary {
  weekly_trend: WeekEntry[];
}

interface Props {
  discussionsSummary: DiscussionSummary;
}

const { discussionsSummary } = Astro.props;

const trend = discussionsSummary?.weekly_trend ?? [];
const isEmpty = trend.length === 0;
---

<ChartCard
  title="Discussion Activity (Weekly)"
  canvasId="discussion-activity-chart"
  height={260}
  isEmpty={isEmpty}
  emptyMsg="No discussion data available yet."
  rangeId="discussion-range-btns"
  ranges={[{ label: '30d', value: '30d' }, { label: '60d', value: '60d' }, { label: '365d', value: '365d' }]}
  defaultRange="30d"
/>
{!isEmpty && (
  <script type="application/json" id="discussion-activity-data" set:html={safeJson({ trend })}></script>
)}

{!isEmpty && (
<script>
  import '../lib/chart-registry.js';
  import { readChartData } from '../lib/inject.js';
  import { BRAND_COLOURS, getChartColors, applyTheme } from '../lib/chart-theme.js';
  import { Chart } from 'chart.js';

  const { trend } = readChartData<{
    trend: { week: string; discussions: number; comments: number }[];
  }>('discussion-activity-data');

  // Slice weekly_trend by range window
  const slices: Record<string, typeof trend> = {
    '30d': trend.slice(-4),
    '60d': trend.slice(-9),
    '365d': trend,
  };

  const colors = getChartColors();
  const initialSlice = slices['30d'];

  let chart: Chart | undefined;
  try {
    chart = new Chart(document.getElementById('discussion-activity-chart') as HTMLCanvasElement, {
      type: 'line',
      data: {
        labels: initialSlice.map(t => t.week),
        datasets: [
          {
            label: 'Discussions',
            data: initialSlice.map(t => t.discussions),
            borderColor: BRAND_COLOURS[0],
            backgroundColor: BRAND_COLOURS[0] + '22',
            fill: true,
            tension: 0.3,
            pointRadius: 4,
          },
          {
            label: 'Comments',
            data: initialSlice.map(t => t.comments),
            borderColor: BRAND_COLOURS[1],
            backgroundColor: BRAND_COLOURS[1] + '22',
            fill: true,
            tension: 0.3,
            pointRadius: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { labels: { color: colors.text, font: { size: 12 } } },
        },
        scales: {
          x: {
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
          },
          y: {
            beginAtZero: true,
            ticks: { color: colors.muted, font: { size: 11 } },
            grid: { color: colors.grid },
          },
        },
      },
    });
  } catch (e) {
    console.error('[DiscussionActivityChart] Chart.js init failed:', e);
  }

  document.querySelectorAll('#discussion-range-btns [data-range]').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!chart) return;
      const range = (btn as HTMLElement).dataset.range!;
      document.querySelectorAll('#discussion-range-btns [data-range]').forEach(b => b.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      const slice = slices[range];
      chart.data.labels = slice.map(t => t.week);
      chart.data.datasets[0].data = slice.map(t => t.discussions);
      chart.data.datasets[1].data = slice.map(t => t.comments);
      chart.update();
    });
  });

  window.addEventListener('themechange', () => {
    if (!chart) return;
    applyTheme(chart);
  });
</script>
)}
